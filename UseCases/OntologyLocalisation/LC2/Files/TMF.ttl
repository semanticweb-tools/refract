@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mesh: <http://purl.bioontology.org/ontology/MESH/> .
@prefix meshza: <https://example.org/mesh/za#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_lc2 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for localisation of MeSH to South African Viewpoint"@en ;
    fract:transformationType fract:OntologyLocalisationProcess ;
    fract:transformationSource <http://purl.bioontology.org/ontology/MESH/> ;
    fract:hasURIRelationshipToSource fract:DifferentRelationship ;
    fract:targetOntologyURI <https://example.org/mesh/za> ;
    fract:targetViewpoint <https://semanticweb.tools/rdf/multi/southafrica> ;
    fract:versionManifest fract:tmf_lc2_v1 ;
    dash:shape shape:ShapeLocalisation ;
    fract:hasAction fract:action_lc2_1, fract:action_lc2_2, fract:action_lc2_3,
                  fract:action_lc2_4, fract:action_lc2_5, fract:action_lc2_6,
                  fract:action_lc2_7, fract:action_lc2_8 ;
    fract:actionOrder (
        fract:action_lc2_1
        fract:action_lc2_2
        fract:action_lc2_3
        fract:action_lc2_4
        fract:action_lc2_5
        fract:action_lc2_6
        fract:action_lc2_7
        fract:action_lc2_8
    ) .

fract:tmf_lc2_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_lc2_1 a fract:ChangeAnnotationValue ;
    fract:sourceNode mesh:D000095083 ;
    fract:targetAnnotation skos:prefLabel ;
    fract:targetAnnotationValue "Traditional Healer" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeChangeAnnotationValue .

fract:action_lc2_2 a fract:AddClass ;
    fract:targetIdentifier meshza:Sangoma ;
    fract:targetParent mesh:D000095083 ;
    fract:targetLabel "Sangoma" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc2_3 a fract:AddClass ;
    fract:targetIdentifier meshza:Herbalist ;
    fract:targetParent mesh:D000095083 ;
    fract:targetLabel "Herbalist" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc2_4 a fract:AddClass ;
    fract:targetIdentifier meshza:TraditionalBirthAttendant ;
    fract:targetParent mesh:D000095083 ;
    fract:targetLabel "Traditional Birth Attendant" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc2_5 a fract:AddClass ;
    fract:targetIdentifier meshza:TraditionalSurgeon ;
    fract:targetParent mesh:D000095083 ;
    fract:targetLabel "Traditional Surgeon" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc2_6 a fract:AddClass ;
    fract:targetIdentifier meshza:MedicineSouthAfricanTraditional ;
    fract:targetParent mesh:D016488 ;
    fract:targetLabel "Medicine, South African Traditional" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc2_7 a fract:AddSuperclassAssertion ;
    fract:sourceNode meshza:MedicineSouthAfricanTraditional ;
    fract:targetParent mesh:D013812 ;
    dash:shape shape:ShapeAddSuperclassAssertion .

fract:action_lc2_8 a fract:AddAnnotationLangString ;
    fract:sourceNode mesh:D000095083 ;
    fract:targetAnnotation skos:altLabel ;
    fract:targetAnnotationValue "Traditional Medicine Practitioners" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .
