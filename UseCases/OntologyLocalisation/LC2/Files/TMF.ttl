@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mesh: <http://purl.bioontology.org/ontology/MESH/> .
@prefix meshza: <https://example.org/mesh/za#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ref:tmf_lc2 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for localisation of MeSH to South African Viewpoint"@en ;
    ref:transformationType ref:OntologyLocalisationProcess ;
    ref:transformationSource <http://purl.bioontology.org/ontology/MESH/> ;
    ref:hasURIRelationshipToSource ref:Different ;
    ref:targetOntologyURI <https://example.org/mesh/za> ;
    ref:targetViewpoint <https://semanticweb.tools/rdf/multi/southafrica> ;
    ref:versionManifest ref:tmf_lc2_v1 ;
    dash:shape shape:ShapeLocalisation ;
    ref:hasAction ref:action_lc2_1, ref:action_lc2_2, ref:action_lc2_3,
                  ref:action_lc2_4, ref:action_lc2_5, ref:action_lc2_6,
                  ref:action_lc2_7, ref:action_lc2_8 ;
    ref:actionOrder (
        ref:action_lc2_1
        ref:action_lc2_2
        ref:action_lc2_3
        ref:action_lc2_4
        ref:action_lc2_5
        ref:action_lc2_6
        ref:action_lc2_7
        ref:action_lc2_8
    ) .

ref:tmf_lc2_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_lc2_1 a ref:ChangeAnnotationValue ;
    ref:sourceNode mesh:D000095083 ;
    ref:targetAnnotation skos:prefLabel ;
    ref:targetAnnotationValue "Traditional Healer" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeChangeAnnotationValue .

ref:action_lc2_2 a ref:AddClass ;
    ref:targetIdentifier meshza:Sangoma ;
    ref:targetParent mesh:D000095083 ;
    ref:targetLabel "Sangoma" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc2_3 a ref:AddClass ;
    ref:targetIdentifier meshza:Herbalist ;
    ref:targetParent mesh:D000095083 ;
    ref:targetLabel "Herbalist" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc2_4 a ref:AddClass ;
    ref:targetIdentifier meshza:TraditionalBirthAttendant ;
    ref:targetParent mesh:D000095083 ;
    ref:targetLabel "Traditional Birth Attendant" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc2_5 a ref:AddClass ;
    ref:targetIdentifier meshza:TraditionalSurgeon ;
    ref:targetParent mesh:D000095083 ;
    ref:targetLabel "Traditional Surgeon" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc2_6 a ref:AddClass ;
    ref:targetIdentifier meshza:MedicineSouthAfricanTraditional ;
    ref:targetParent mesh:D016488 ;
    ref:targetLabel "Medicine, South African Traditional" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc2_7 a ref:AddSuperclassAssertion ;
    ref:sourceNode meshza:MedicineSouthAfricanTraditional ;
    ref:targetParent mesh:D013812 ;
    dash:shape shape:ShapeAddSuperclassAssertion .

ref:action_lc2_8 a ref:AddAnnotationLangString ;
    ref:sourceNode mesh:D000095083 ;
    ref:targetAnnotation skos:altLabel ;
    ref:targetAnnotationValue "Traditional Medicine Practitioners" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .
