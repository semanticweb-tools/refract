@prefix sweet: <http://sweetontology.net/realmHydroBody/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://sweetontology.net/realmHydroBody>
    a owl:Ontology ;
    rdfs:label "SWEET Ontology Realm Hydrosphere Body"@en .

sweet:BodyOfWater a owl:Class ;
    rdfs:label "Body of water"@en .

sweet:NaturalWaterBody a owl:Class ;
    rdfs:label "Natural water body"@en ;
    rdfs:subClassOf sweet:BodyOfWater .

sweet:River a owl:Class ;
    rdfs:label "River"@en ;
    rdfs:subClassOf sweet:NaturalWaterBody .