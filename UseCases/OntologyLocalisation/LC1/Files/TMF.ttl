@prefix ref: <http://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix sweet: <http://sweetontology.net/realmHydroBody/> .
@prefix sweetfr: <https://example.org/sweet/fr#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ref:tmf_lc1 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for localisation of SWEET Ontology Realm Hydrosphere Body to French Viewpoint"@en ;
    ref:transformationType ref:OntologyLocalisationProcess ;
    ref:transformationSource <http://sweetontology.net/realmHydroBody> ;
    ref:startingNode sweet:BodyOfWater ;
    ref:hasURIRelationshipToSource ref:Different ;
    ref:targetOntologyURI <https://example.org/sweet/fr> ;
    ref:targetViewpoint <https://semanticweb.tools/rdf/multi/language-french> ;
    ref:versionManifest ref:tmf_lc1_v1 ;
    dash:shape shape:ShapeLocalisation ;
    ref:hasAction ref:action_lc1_1, ref:action_lc1_2, ref:action_lc1_3,
                  ref:action_lc1_4, ref:action_lc1_5, ref:action_lc1_6 ;
    ref:actionOrder (
        ref:action_lc1_1
        ref:action_lc1_2
        ref:action_lc1_3
        ref:action_lc1_4
        ref:action_lc1_5
        ref:action_lc1_6
    ) .

ref:tmf_lc1_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_lc1_1 a ref:DeleteClass ;
    ref:sourceNode sweet:River ;
    dash:shape shape:ShapeDeleteClass .

ref:action_lc1_2 a ref:AddClass ;
    ref:targetIdentifier sweetfr:Riviere ;
    ref:targetParent sweet:NaturalWaterBody ;
    ref:targetLabel "Rivière" ;
    ref:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc1_3 a ref:AddClass ;
    ref:targetIdentifier sweetfr:Fleuve ;
    ref:targetParent sweet:NaturalWaterBody ;
    ref:targetLabel "Fleuve" ;
    ref:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddClass .

ref:action_lc1_4 a ref:AddSemanticAxiom ;
    ref:sourceNode sweetfr:Riviere ;
    ref:axiomType owl:disjointWith ;
    ref:targetNode sweetfr:Fleuve ;
    dash:shape shape:ShapeAddSemanticAxiom .

ref:action_lc1_5 a ref:AddAnnotationLangString ;
    ref:targetNode sweetfr:Riviere ;
    ref:targetAnnotation skos:definition ;
    ref:targetAnnotationValue "A river that flows into another river." ;
    ref:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_lc1_6 a ref:AddAnnotationLangString ;
    ref:targetNode sweetfr:Fleuve ;
    ref:targetAnnotation skos:definition ;
    ref:targetAnnotationValue "A river that flows into the sea." ;
    ref:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddAnnotationLangString .