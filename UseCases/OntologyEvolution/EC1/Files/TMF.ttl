@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix efo: <http://www.ebi.ac.uk/efo/> .
@prefix ex: <https://example.org/efo/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_ec1 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for evolution of EFO ontology"@en ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://www.ebi.ac.uk/efo/> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:versionManifest fract:tmf_ec1_v1 ;
    dash:shape shape:ShapeEvolution ;
    fract:hasAction fract:action_ec1_1, fract:action_ec1_2, fract:action_ec1_3, fract:action_ec1_4, fract:action_ec1_5 ;
    fract:actionOrder (
        fract:action_ec1_1
        fract:action_ec1_2
        fract:action_ec1_3
        fract:action_ec1_4
        fract:action_ec1_5
    ) .

fract:tmf_ec1_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_ec1_1 a fract:AddClass ;
    fract:targetIdentifier ex:ArtificialIntelligence ;
    fract:targetParent efo:EFO_0004542 ;
    fract:targetLabel "Artificial intelligence" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_ec1_2 a fract:AddClass ;
    fract:targetIdentifier ex:DistributedIntelligence ;
    fract:targetParent efo:EFO_0003925 ;
    fract:targetLabel "Distributed intelligence" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_ec1_3 a fract:AddEquivalentClassSet ;
    fract:targetNode ex:DistributedIntelligence ;
    fract:targetMembers ( efo:EFO_0004337 ex:ArtificialIntelligence ) ;
    fract:setType owl:unionOf ;
    dash:shape shape:ShapeAddEquivalentClassSet .

fract:action_ec1_4 a fract:AddAnnotationLangString ;
    fract:targetNode ex:DistributedIntelligence ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "The cognitive capacity emerging from the partnership between human and artificial intelligence systems." ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

fract:action_ec1_5 a fract:AddAnnotationLangString ;
    fract:targetNode ex:ArtificialIntelligence ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "Machines capable of performing tasks that typically require human intelligence." ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .
