@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mesh: <http://purl.bioontology.org/ontology/MESH/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ref:tmf_ec2 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for evolution of MeSH ontology"@en ;
    ref:transformationType ref:OntologyEvolutionProcess ;
    ref:transformationSource <http://purl.bioontology.org/ontology/MESH/> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:versionManifest ref:tmf_ec2_v1 ;
    dash:shape shape:ShapeEvolution ;
    ref:hasAction ref:action_ec2_1, ref:action_ec2_2, ref:action_ec2_3 ;
    ref:actionOrder (
        ref:action_ec2_1
        ref:action_ec2_2
        ref:action_ec2_3
    ) .

ref:tmf_ec2_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_ec2_1 a ref:ChangeAnnotationValue ;
    ref:sourceNode mesh:D005062 ;
    ref:targetAnnotation skos:definition ;
    ref:targetAnnotationValue "An economic union with the principal objectives of free movement of goods, capital, and labor. The constituent countries are Austria, Belgium, Bulgaria, Croatia, Cyprus, Czech Republic, Denmark, Estonia, Finland, France, Germany, Greece, Hungary, Ireland, Italy, Latvia, Lithuania, Luxembourg, Malta, Netherlands, Poland, Portugal, Romania, Slovakia, Slovenia, Spain, and Sweden. (https://europa.eu/european-union/about-eu/countries accessed 31/01/2020)" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeChangeAnnotationValue .

ref:action_ec2_2 a ref:AddAnnotationLangString ;
    ref:sourceNode mesh:D005062 ;
    ref:targetAnnotation skos:historyNote ;
    ref:targetAnnotationValue "The United Kingdom was a member of the European Union until 31 January 2020, when it formally withdrew following the Brexit referendum of 23 June 2016." ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_ec2_3 a ref:AddAnnotation ;
    ref:sourceNode mesh:D005062 ;
    ref:targetAnnotation dct:modified ;
    ref:targetAnnotationValue "2020-01-31" ;
    ref:targetDataType xsd:date ;
    dash:shape shape:ShapeAddAnnotation .
