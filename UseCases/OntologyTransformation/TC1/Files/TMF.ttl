@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix recipe: <https://example.org/recipe#> .
@prefix recipeim: <https://example.org/recipe/imperial#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ref:tmf_tc1 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for transformation of Recipe Measurement Ontology to Imperial Viewpoint"@en ;
    ref:transformationType ref:OntologyTransformationProcess ;
    ref:transformationSource <https://example.org/recipe> ;
    ref:hasURIRelationshipToSource ref:Different ;
    ref:targetOntologyURI <https://example.org/recipe/imperial> ;
    ref:targetViewpoint <https://semanticweb.tools/rdf/multi/imperial> ;
    ref:versionManifest ref:tmf_tc1_v1 ;
    dash:shape shape:ShapeTransformation ;
    ref:hasAction ref:action_tc1_1, ref:action_tc1_2, ref:action_tc1_3, ref:action_tc1_4,
                  ref:action_tc1_5, ref:action_tc1_6, ref:action_tc1_7, ref:action_tc1_8,
                  ref:action_tc1_9, ref:action_tc1_10, ref:action_tc1_11, ref:action_tc1_12 ;
    ref:actionOrder (
        ref:action_tc1_1
        ref:action_tc1_2
        ref:action_tc1_3
        ref:action_tc1_4
        ref:action_tc1_5
        ref:action_tc1_6
        ref:action_tc1_7
        ref:action_tc1_8
        ref:action_tc1_9
        ref:action_tc1_10
        ref:action_tc1_11
        ref:action_tc1_12
    ) .

ref:tmf_tc1_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_tc1_1 a ref:AddClass ;
    ref:targetIdentifier recipeim:ImperialUnit ;
    ref:targetParent recipe:Unit ;
    ref:targetLabel "Imperial unit" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc1_2 a ref:AddClass ;
    ref:targetIdentifier recipeim:Ounce ;
    ref:targetParent recipeim:ImperialUnit ;
    ref:targetLabel "Ounce" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc1_3 a ref:AddClass ;
    ref:targetIdentifier recipeim:FluidOunce ;
    ref:targetParent recipeim:ImperialUnit ;
    ref:targetLabel "Fluid ounce" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc1_4 a ref:AddClass ;
    ref:targetIdentifier recipeim:Fahrenheit ;
    ref:targetParent recipeim:ImperialUnit ;
    ref:targetLabel "Degree Fahrenheit" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc1_5 a ref:AddAnnotation ;
    ref:targetNode recipeim:Ounce ;
    ref:targetAnnotation qudt:conversionMultiplier ;
    ref:targetAnnotationValue "28.3495" ;
    ref:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

ref:action_tc1_6 a ref:AddAnnotation ;
    ref:targetNode recipeim:FluidOunce ;
    ref:targetAnnotation qudt:conversionMultiplier ;
    ref:targetAnnotationValue "29.5735" ;
    ref:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

ref:action_tc1_7 a ref:AddAnnotation ;
    ref:targetNode recipeim:Fahrenheit ;
    ref:targetAnnotation qudt:conversionMultiplier ;
    ref:targetAnnotationValue "1.8" ;
    ref:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

ref:action_tc1_8 a ref:AddAnnotation ;
    ref:targetNode recipeim:Fahrenheit ;
    ref:targetAnnotation qudt:conversionOffset ;
    ref:targetAnnotationValue "32" ;
    ref:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

ref:action_tc1_9 a ref:DeleteClass ;
    ref:sourceNode recipe:MetricUnit ;
    dash:shape shape:ShapeDeleteClass .

ref:action_tc1_10 a ref:DeleteClass ;
    ref:sourceNode recipe:Gram ;
    dash:shape shape:ShapeDeleteClass .

ref:action_tc1_11 a ref:DeleteClass ;
    ref:sourceNode recipe:Millilitre ;
    dash:shape shape:ShapeDeleteClass .

ref:action_tc1_12 a ref:DeleteClass ;
    ref:sourceNode recipe:Celsius ;
    dash:shape shape:ShapeDeleteClass .
