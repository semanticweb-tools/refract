@prefix mola: <https://semanticweb.tools/ont/mola#> .
@prefix molarlf: <https://semanticweb.tools/ont/mola/rl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

<https://semanticweb.tools/ont/mola/rl>
    a owl:Ontology ;
    rdfs:label "MoLA Ontology - OWL2_RL Context"@en ;
    prov:wasDerivedFrom <https://semanticweb.tools/ont/mola> ;
    dct:created "2025-01-01"^^xsd:date .

mola:DialectCluster a owl:Class ;
    rdfs:label "Dialect cluster"@en .

mola:LanguageFamily a owl:Class ;
    rdfs:label "Language family"@en .

mola:GeographicCoordinate a owl:Class ;
    rdfs:label "Geographic coordinate"@en .

mola:Region a owl:Class ;
    rdfs:label "Region"@en .

mola:hasMember a owl:ObjectProperty ;
    rdfs:label "has member"@en ;
    rdfs:domain mola:DialectCluster ;
    rdfs:domain mola:LanguageFamily .

mola:hasCoordinate a owl:ObjectProperty ;
    rdfs:label "has coordinate"@en .
