@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mola: <https://semanticweb.tools/ont/mola#> .

ref:tmf_tc3 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for transformation of MoLA Ontology to OWL2_RL Context"@en ;
    ref:transformationType ref:OntologyTransformationProcess ;
    ref:transformationSource <https://semanticweb.tools/ont/mola> ;
    ref:hasURIRelationshipToSource ref:Different ;
    ref:targetOntologyURI <https://semanticweb.tools/ont/mola/rl> ;
    ref:targetViewpoint <https://semanticweb.tools/rdf/multi/owl2rl> ;
    ref:versionManifest ref:tmf_tc3_v1 ;
    dash:shape shape:ShapeTransformation ;
    ref:hasAction ref:action_tc3_1, ref:action_tc3_2, ref:action_tc3_3, ref:action_tc3_4 ;
    ref:actionOrder (
        ref:action_tc3_1
        ref:action_tc3_2
        ref:action_tc3_3
        ref:action_tc3_4
    ) .

ref:tmf_tc3_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_tc3_1 a ref:DeleteCardinalityRestriction ;
    ref:sourceNode mola:Region ;
    ref:sourceProperty mola:hasCoordinate ;
    ref:sourceOnClass mola:GeographicCoordinate ;
    dash:shape shape:ShapeDeleteCardinalityRestriction .

ref:action_tc3_2 a ref:DeletePropertyDomainRange ;
    ref:sourceNode mola:hasMember ;
    ref:axiomType rdfs:domain ;
    dash:shape shape:ShapeDeletePropertyDomainRange .

ref:action_tc3_3 a ref:AddPropertyDomainRange ;
    ref:sourceNode mola:hasMember ;
    ref:targetNode mola:DialectCluster ;
    ref:axiomType rdfs:domain ;
    ref:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyDomainRange .

ref:action_tc3_4 a ref:AddPropertyDomainRange ;
    ref:sourceNode mola:hasMember ;
    ref:targetNode mola:LanguageFamily ;
    ref:axiomType rdfs:domain ;
    ref:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyDomainRange .
