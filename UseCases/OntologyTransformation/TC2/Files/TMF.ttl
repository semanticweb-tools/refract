@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ch: <https://example.org/ch#> .
@prefix chc: <https://example.org/ch/contested#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

ref:tmf_tc2 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for transformation of Cultural Heritage Ontology to Contested Heritage Viewpoint"@en ;
    ref:transformationType ref:OntologyTransformationProcess ;
    ref:transformationSource <https://example.org/ch> ;
    ref:hasURIRelationshipToSource ref:Different ;
    ref:targetOntologyURI <https://example.org/ch/contested> ;
    ref:targetViewpoint <https://semanticweb.tools/rdf/multi/contested> ;
    ref:versionManifest ref:tmf_tc2_v1 ;
    dash:shape shape:ShapeTransformation ;
    ref:hasAction ref:action_tc2_0, ref:action_tc2_1, ref:action_tc2_2, ref:action_tc2_3,
                  ref:action_tc2_4, ref:action_tc2_5, ref:action_tc2_6, ref:action_tc2_7,
                  ref:action_tc2_8, ref:action_tc2_9, ref:action_tc2_10, ref:action_tc2_11,
                  ref:action_tc2_12, ref:action_tc2_13, ref:action_tc2_14, ref:action_tc2_15,
                  ref:action_tc2_16, ref:action_tc2_17, ref:action_tc2_18, ref:action_tc2_19,
                  ref:action_tc2_20 ;
    ref:actionOrder (
        ref:action_tc2_0
        ref:action_tc2_1
        ref:action_tc2_2
        ref:action_tc2_3
        ref:action_tc2_4
        ref:action_tc2_5
        ref:action_tc2_6
        ref:action_tc2_7
        ref:action_tc2_8
        ref:action_tc2_9
        ref:action_tc2_10
        ref:action_tc2_11
        ref:action_tc2_12
        ref:action_tc2_13
        ref:action_tc2_14
        ref:action_tc2_15
        ref:action_tc2_16
        ref:action_tc2_17
        ref:action_tc2_18
        ref:action_tc2_19
        ref:action_tc2_20
    ) .

ref:tmf_tc2_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_tc2_0 a ref:RenameClass ;
    ref:sourceNode ch:VenusHottentote ;
    ref:targetIdentifier ch:SarahBaartman ;
    ref:targetLabel "Sarah Baartman" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeRenameClass .

ref:action_tc2_1 a ref:AddClass ;
    ref:targetIdentifier chc:HumanRemains ;
    ref:targetParent ch:CulturalObject ;
    ref:targetLabel "Human remains" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc2_2 a ref:AddAnnotationLangString ;
    ref:targetNode chc:HumanRemains ;
    ref:targetAnnotation skos:definition ;
    ref:targetAnnotationValue "The physical remains of a person, recognised as deserving dignity and respect regardless of their current location." ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_tc2_3 a ref:AddClass ;
    ref:targetIdentifier chc:ContestedHeritage ;
    ref:targetParent ch:CulturalObject ;
    ref:targetLabel "Contested heritage" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc2_4 a ref:AddAnnotationLangString ;
    ref:targetNode chc:ContestedHeritage ;
    ref:targetAnnotation skos:definition ;
    ref:targetAnnotationValue "Cultural objects or human remains whose ownership, display, or acquisition is disputed on ethical, historical, or cultural grounds." ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_tc2_5 a ref:AddClass ;
    ref:targetIdentifier chc:Repatriation ;
    ref:targetParent owl:Thing ;
    ref:targetLabel "Repatriation" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc2_6 a ref:AddAnnotationLangString ;
    ref:targetNode chc:Repatriation ;
    ref:targetAnnotation skos:definition ;
    ref:targetAnnotationValue "The process of returning cultural objects or human remains to their community or country of origin." ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_tc2_7 a ref:AddClass ;
    ref:targetIdentifier chc:ConsentStatus ;
    ref:targetParent owl:Thing ;
    ref:targetLabel "Consent status" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

ref:action_tc2_8 a ref:AddInstance ;
    ref:targetIdentifier chc:ConsentGivenExplicit ;
    ref:targetInstanceOf chc:ConsentStatus ;
    ref:targetLabel "Consent given (explicit)" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddInstance .

ref:action_tc2_9 a ref:AddInstance ;
    ref:targetIdentifier chc:ConsentNotGivenExplicit ;
    ref:targetInstanceOf chc:ConsentStatus ;
    ref:targetLabel "Consent not given (explicit)" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddInstance .

ref:action_tc2_10 a ref:AddInstance ;
    ref:targetIdentifier chc:ConsentNotGivenImplicit ;
    ref:targetInstanceOf chc:ConsentStatus ;
    ref:targetLabel "Consent not given (implicit)" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddInstance .

ref:action_tc2_11 a ref:AddInstance ;
    ref:targetIdentifier chc:ConsentUnknown ;
    ref:targetInstanceOf chc:ConsentStatus ;
    ref:targetLabel "Consent unknown" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddInstance .

ref:action_tc2_12 a ref:ChangeInstanceAssertion ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetNode chc:HumanRemains ;
    dash:shape shape:ShapeChangeInstanceAssertion .

ref:action_tc2_13 a ref:DeleteAnnotation ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetAnnotation skos:prefLabel ;
    dash:shape shape:ShapeDeleteAnnotation .

ref:action_tc2_14 a ref:DeleteAnnotation ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetAnnotation rdfs:label ;
    dash:shape shape:ShapeDeleteAnnotation .

ref:action_tc2_15 a ref:AddAnnotationLangString ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetAnnotation rdfs:label ;
    ref:targetAnnotationValue "Sarah Baartman" ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_tc2_16 a ref:AddInstancePropertyAssertion ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetObject chc:donationConsentStatus ;
    ref:targetObjectValue chc:ConsentNotGivenImplicit ;
    ref:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddInstancePropertyAssertion .

ref:action_tc2_17 a ref:AddAnnotationLangString ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetAnnotation skos:historyNote ;
    ref:targetAnnotationValue "Known in colonial records as 'Venus Hottentote' and 'Saartjie Baartman'. These labels are considered disrespectful and have been removed." ;
    ref:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_tc2_18 a ref:AddAnnotation ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetAnnotation ch:removedFromDisplay ;
    ref:targetAnnotationValue "1974" ;
    ref:targetDataType xsd:gYear ;
    dash:shape shape:ShapeAddAnnotation .

ref:action_tc2_19 a ref:AddInstancePropertyAssertion ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetObject chc:repatriatedTo ;
    ref:targetObjectValue <https://example.org/ch/southafrica> ;
    ref:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddInstancePropertyAssertion .

ref:action_tc2_20 a ref:AddAnnotation ;
    ref:sourceNode ch:SarahBaartman ;
    ref:targetAnnotation chc:repatriationDate ;
    ref:targetAnnotationValue "2002-05-06" ;
    ref:targetDataType xsd:date ;
    dash:shape shape:ShapeAddAnnotation .
