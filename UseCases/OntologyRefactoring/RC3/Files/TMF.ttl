@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix multi: <https://w3id.org/MULTI#> .

ref:tmf_rc3 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for refactoring of MULTI ontology"@en ;
    ref:transformationType ref:OntologyRefactoringProcess ;
    ref:transformationSource <https://w3id.org/MULTI> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:versionManifest ref:tmf_rc3_v1 ;
    dash:shape shape:ShapeRefactoring ;
    ref:hasAction ref:action_rc3_1, ref:action_rc3_2 .

ref:tmf_rc3_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_rc3_1 a ref:AddAnnotationLangString ;
    ref:sourceNode multi:Viewpoint ;
    ref:targetAnnotation rdfs:label ;
    ref:targetAnnotationValue "Standpunt" ;
    ref:targetLanguageTag "af" ;
    dash:shape shape:ShapeAddAnnotationLangString .

ref:action_rc3_2 a ref:AddAnnotationLangString ;
    ref:sourceNode multi:Viewpoint ;
    ref:targetAnnotation rdfs:label ;
    ref:targetAnnotationValue "Point de vue" ;
    ref:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddAnnotationLangString .
