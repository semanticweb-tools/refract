@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mola: <https://semanticweb.tools/ont/mola#> .

ref:tmf_rc2 a ref:Manifest ;
    rdfs:label "Manifest 1.0.0 for (partial) refactoring of MoLA ontology to OWL2_RL"@en ;
    ref:transformationType ref:OntologyRefactoringProcess ;
    ref:transformationSource <https://semanticweb.tools/ont/mola> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:versionManifest ref:tmf_rc2_v1 ;
    dash:shape shape:ShapeRefactoring ;
    ref:hasAction ref:action_rc2_1 .

ref:tmf_rc2_v1 a ref:Version ;
    ref:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    ref:versionPrevious ref:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

ref:action_rc2_1 a ref:DeleteSuperclassAssertion ;
    ref:sourceNode mola:LanguageCode, mola:Period, mola:LanguoidName,
                   mola:GeographicCoordinate, mola:Languoid, mola:LanguageTag ;
    ref:targetSuperclass owl:Thing ;
    dash:shape shape:ShapeDeleteSuperclassAssertion .
