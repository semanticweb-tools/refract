@prefix : <https://w3id.org/refract#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix mod: <https://w3id.org/mod#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix multi: <https://semanticweb.tools/ont/multi#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/refract#> .

<https://w3id.org/refract> rdf:type owl:Ontology ;
                            owl:versionIRI <https://w3id.org/refract/1.0.0> ;
                            owl:imports <https://semanticweb.tools/ont/dash> ,
                                        <https://semanticweb.tools/ont/shacl> ;
                            cc:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
                            dc:creator "Frances Gillis-Webber" ;
                            dc:description """REFrACT is a vocabulary for describing and validating a Transformation Manifest File (TMF). A TMF records the metadata and refactoring actions associated with an ontology transformation process, including refactoring, evolution, transformation, and localisation. REFrACT has been aligned to the DASH Data Shapes Vocabulary, which in turn imports the Shapes Constraint Language (SHACL).

REFrACT provides a controlled vocabulary of refactoring action types, each with associated SHACL shapes graphs for validation, enabling the provenance and configuration metadata of ontology transformation processes to be captured in a machine-readable and reusable form. An example TMF is provided for each refactoring action."""@en ;
                            dc:rights "CC-Zero" ;
                            dc:title "Refactoring Actions Shapes Library (REFrACT)"@en ;
                            dcterms:bibliographicCitation "Gillis-Webber, F. (2026) “Refactoring Actions Shapes Library (REFrACT)”. Zenodo. doi:10.5281/zenodo.20742085."@en ;
                            dcterms:created "2026-05-16"^^xsd:date ;
                            dcterms:issued "2026-06-16"^^xsd:date ;
                            dcterms:modified "2026-06-18" ;
                            dcterms:publisher "Frances Gillis-Webber c/o SemanticWeb.tools" ;
                            dcterms:source <https://github.com/semanticweb-tools/refract> ;
                            bibo:doi <10.5281/zenodo.20742085> ;
                            vann:preferredNamespacePrefix "fract" ;
                            vann:preferredNamespaceUri "https://w3id.org/refract#" ;
                            rdfs:comment "The SHACL shapes graphs, example Transformation Manifest Files, rdfs:comments, and fract:hasParameters annotations for each refactoring action were generated with the assistance of Claude Sonnet 4.6 by Anthropic. If you identify any discrepancies, please contact Frances Gillis-Webber at fgilliswebber@cs.uct.ac.za."@en ;
                            rdfs:label "REFrACT" ;
                            owl:versionInfo "1.0.0" ;
                            foaf:logo <https://semanticweb.tools/logo.png> ;
                            mod:status "stable" .

#################################################################
#    Annotation properties
#################################################################

###  http://creativecommons.org/ns#license
cc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/rights
dc:rights rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
dcterms:abstract rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:AnnotationProperty ;
                              rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/date
dcterms:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:AnnotationProperty ;
                  rdfs:isDefinedBy dcterms: .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy dcterms: .


###  http://purl.org/ontology/bibo/doi
bibo:doi rdf:type owl:AnnotationProperty ;
         rdfs:isDefinedBy bibo: .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
<http://www.w3.org/2004/02/skos/core#note> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/logo
foaf:logo rdf:type owl:AnnotationProperty .


###  https://w3id.org/mod#status
mod:status rdf:type owl:AnnotationProperty ;
           rdfs:isDefinedBy <https://w3id.org/mod> .


###  https://w3id.org/refract#exampleTMF
:exampleTMF rdf:type owl:AnnotationProperty ;
            rdfs:comment "An annotation property used internally to provide an example Transformation Manifest File (TMF) for a refactoring action, for documentation purposes. This property is not intended for external use. For more information on the TMF, see the REFrACT documentation."@en ;
            rdfs:isDefinedBy <https://w3id.org/refract> ;
            rdfs:label "example TMF"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :exampleTMF ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "An annotation property used internally to provide an example Transformation Manifest File (TMF) for a refactoring action, for documentation purposes. This property is not intended for external use. For more information on the TMF, see the REFrACT documentation."@en ;
   rdfs:seeAlso <https://semanticweb.tools/site/refract/>
 ] .


###  https://w3id.org/refract#hasActions
:hasActions rdf:type owl:AnnotationProperty ;
            rdfs:comment "An annotation property used internally to describe the constituent actions of a composite refactoring action for documentation purposes. This property is not intended for external use."@en ;
            rdfs:isDefinedBy <https://w3id.org/refract> ;
            rdfs:label "has actions"@en .


###  https://w3id.org/refract#hasOptionalParameter
:hasOptionalParameter rdf:type owl:AnnotationProperty ;
                      rdfs:comment "An annotation property used internally to indicate an optional parameter of a refactoring action, for documentation purposes. This property is not intended for external use."@en ;
                      rdfs:isDefinedBy <https://w3id.org/refract> ;
                      rdfs:label "is optional parameter"@en .


###  https://w3id.org/refract#hasOptionalParameterWithAtLeastOne
:hasOptionalParameterWithAtLeastOne rdf:type owl:AnnotationProperty ;
                                    rdfs:comment "An annotation property used internally to indicate a parameter of a refactoring action that is individually optional, but where at least one parameter from the group must be specified. For documentation purposes only. This property is not intended for external use."@en ;
                                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                                    rdfs:label "is optional parameter (with at least one)"@en .


###  https://w3id.org/refract#hasOptionalParameterWithFallback
:hasOptionalParameterWithFallback rdf:type owl:AnnotationProperty ;
                                  rdfs:comment "An annotation property used internally to indicate an optional parameter of a refactoring action that has a default fallback value. If the parameter is omitted from the transformation manifest, the algorithm will inject the fallback value at runtime. For documentation purposes only. This property is not intended for external use."@en ;
                                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                                  rdfs:label "is optional parameter (with fallback)"@en .


###  https://w3id.org/refract#hasParameters
:hasParameters rdf:type owl:AnnotationProperty ;
               rdfs:comment "An annotation property used internally to describe the parameters of a refactoring action for documentation purposes. This property is not intended for external use."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "has parameters"@en .


###  https://w3id.org/refract#hasRequiredParameter
:hasRequiredParameter rdf:type owl:AnnotationProperty ;
                      rdfs:comment "An annotation property used internally to indicate a required parameter of a refactoring action, for documentation purposes. This property is not intended for external use."@en ;
                      rdfs:isDefinedBy <https://w3id.org/refract> ;
                      rdfs:label "is required parameter"@en .


###  https://w3id.org/refract#hasShapesGraph
:hasShapesGraph rdf:type owl:AnnotationProperty ;
                rdfs:comment "Links a refactoring action to its associated SHACL shapes graph, which can be used to validate a Transformation Manifest File containing that action."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "has shapes graph"@en .


###  https://w3id.org/refract#isOptionalAction
:isOptionalAction rdf:type owl:AnnotationProperty ;
                  rdfs:comment "An annotation property used internally to indicate an optional constituent action of a composite refactoring action, for documentation purposes. This property is not intended for external use."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "is optional action"@en .


###  https://w3id.org/refract#isRequiredAction
:isRequiredAction rdf:type owl:AnnotationProperty ;
                  rdfs:comment "An annotation property used internally to indicate a required constituent action of a composite refactoring action, for documentation purposes. This property is not intended for external use."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "is required action"@en .


###  https://w3id.org/refract#targetRights
:targetRights rdf:type owl:AnnotationProperty ;
              rdfs:comment "Specifies the rights of the target ontology. The value may be 'Target same as source' if the rights are the same as the source ontology, or a URI to a licence such as a Creative Commons licence. If omitted, the rights of the target ontology are unknown."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "target rights"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :targetRights ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Specifies the rights of the target ontology. The value may be 'Target same as source' if the rights are the same as the source ontology, or a URI to a licence such as a Creative Commons licence. If omitted, the rights of the target ontology are unknown."@en ;
   rdfs:seeAlso :TargetSameAsSource
 ] .


###  https://w3id.org/refract#versionNumber
:versionNumber rdf:type owl:AnnotationProperty ;
               rdfs:comment "The version number of a Transformation Manifest File, expressed as a plain string (e.g. \"1.0.0\")."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "version number"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :versionNumber ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "The version number of a Transformation Manifest File, expressed as a plain string (e.g. \"1.0.0\")."@en ;
   rdfs:seeAlso :Manifest
 ] .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:ObjectProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:ObjectProperty ;
                rdfs:isDefinedBy "http://purl.org/dc/terms/" ;
                rdfs:label "license"@en .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:ObjectProperty ;
                    rdfs:comment "11-06-2026: Possibly needs to be removed."@en ;
                    rdfs:isDefinedBy "https://www.w3.org/ns/prov" ;
                    rdfs:label "was derived from"@en .


###  https://semanticweb.tools/ont/multi#hasViewpoint
multi:hasViewpoint rdf:type owl:ObjectProperty ;
                   rdfs:comment "Links an entity to the viewpoint it represents or is associated with, as defined in the MULTI ontology."@en ;
                   rdfs:isDefinedBy "https://semanticweb.tools/ont/multi" ;
                   rdfs:label "has viewpoint"@en .


###  https://w3id.org/refract#actionOrder
:actionOrder rdf:type owl:ObjectProperty ;
             rdfs:comment "Specifies the execution order of the top-level refactoring actions in a Transformation Manifest File, expressed as an rdf:list of action URIs. If omitted, the algorithm will execute the actions in the order they appear in the manifest."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "action order"@en .


###  https://w3id.org/refract#axiomType
:axiomType rdf:type owl:ObjectProperty ;
           rdfs:comment "Specifies the type of axiom used in a refactoring action. The value must be a URI representing a valid OWL or RDF axiom type."@en ;
           rdfs:isDefinedBy <https://w3id.org/refract> ;
           rdfs:label "axiom type"@en .


###  https://w3id.org/refract#checkForAnnotation
:checkForAnnotation rdf:type owl:ObjectProperty ;
                    rdfs:range :AlgorithmCheckAnnotation ;
                    rdfs:comment "Specifies the behaviour of the transformation algorithm when the annotation to be changed is not found during pre-processing for a change annotation action. The value must be an instance of 'Algorithm check - annotation'. If this parameter is omitted, the algorithm defaults to 'If false - add'."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "check for annotation"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :checkForAnnotation ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Specifies the behaviour of the transformation algorithm when the annotation to be changed is not found during pre-processing for a change annotation action. The value must be an instance of 'Algorithm check - annotation'. If this parameter is omitted, the algorithm defaults to 'If false - add'."@en ;
   rdfs:seeAlso :AlgorithmCheckAnnotation
 ] .


###  https://w3id.org/refract#checkForAssertion
:checkForAssertion rdf:type owl:ObjectProperty ;
                   rdfs:range :AlgorithmCheckAssertion ;
                   rdfs:comment "Specifies the behaviour of the transformation algorithm when existing assertions are found during pre-processing for an element that is to be deleted. The value must be an instance of 'Algorithm check - assertion'. If this parameter is omitted, the algorithm defaults to 'If true - stop'."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "check for assertion"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :checkForAssertion ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Specifies the behaviour of the transformation algorithm when existing assertions are found during pre-processing for an element that is to be deleted. The value must be an instance of 'Algorithm check - assertion'. If this parameter is omitted, the algorithm defaults to 'If true - stop'."@en ;
   rdfs:seeAlso :AlgorithmCheckAssertion
 ] .


###  https://w3id.org/refract#fallbackOntologyURI
:fallbackOntologyURI rdf:type owl:ObjectProperty ;
                     rdfs:comment "The URI of the source ontology, declared on the target ontology manifest to provide backwards compatibility for external resources that were consuming the source ontology at its original URI. Should be declared when 'has URI relationship to source' is 'Different relationship'."@en ;
                     rdfs:isDefinedBy <https://w3id.org/refract> ;
                     rdfs:label "fallback ontology URI"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :fallbackOntologyURI ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "The URI of the source ontology, declared on the target ontology manifest to provide backwards compatibility for external resources that were consuming the source ontology at its original URI. Should be declared when 'has URI relationship to source' is 'Different relationship'."@en ;
   rdfs:seeAlso :DifferentRelationship ,
                :hasURIRelationshipToSource
 ] .


###  https://w3id.org/refract#hasAction
:hasAction rdf:type owl:ObjectProperty ;
           rdfs:comment "Links a composite refactoring action to its constituent atomic actions. The execution order of the atomic actions is specified using 'action sequence'."@en ;
           rdfs:isDefinedBy <https://w3id.org/refract> ;
           rdfs:label "has action"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :hasAction ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Links a composite refactoring action to its constituent atomic actions. The execution order of the atomic actions is specified using 'action sequence'."@en ;
   rdfs:seeAlso :CompositeAction ,
                :actionSequence
 ] .


###  https://w3id.org/refract#hasSemanticCategory
:hasSemanticCategory rdf:type owl:ObjectProperty ;
                     rdfs:range :SemanticCategory ;
                     rdfs:comment "Links a concept transformation to its semantic category, indicating the type of conceptual relationship between the source concept and its corresponding concept(s) in the target viewpoint."@en ;
                     rdfs:isDefinedBy <https://w3id.org/refract> ;
                     rdfs:label "has semantic category"@en .


###  https://w3id.org/refract#hasURIRelationshipToSource
:hasURIRelationshipToSource rdf:type owl:ObjectProperty ;
                            rdfs:comment "Specifies the URI relationship between the source and target ontology. The value must be a subclass of 'URI relationship'."@en ;
                            rdfs:isDefinedBy <https://w3id.org/refract> ;
                            rdfs:label "has URI relationship to source"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :hasURIRelationshipToSource ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Specifies the URI relationship between the source and target ontology. The value must be a subclass of 'URI relationship'."@en ;
   rdfs:seeAlso :URIRelationship
 ] .


###  https://w3id.org/refract#propertyType
:propertyType rdf:type owl:ObjectProperty ;
              rdfs:comment "Specifies the type of property used in a refactoring action. The value must be either owl:ObjectProperty or owl:DatatypeProperty."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "property type"@en .


###  https://w3id.org/refract#restrictionType
:restrictionType rdf:type owl:ObjectProperty ;
                 rdfs:comment "Specifies the type of restriction to be added as part of a refactoring action. The value must be either owl:someValuesFrom (existential restriction) or owl:allValuesFrom (universal restriction)."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "restriction type"@en .


###  https://w3id.org/refract#setType
:setType rdf:type owl:ObjectProperty ;
         rdfs:comment "Specifies the type of set operation used in a set-based equivalent class assertion. The value must be either owl:unionOf or owl:intersectionOf."@en ;
         rdfs:isDefinedBy <https://w3id.org/refract> ;
         rdfs:label "set type"@en .


###  https://w3id.org/refract#sourceNode
:sourceNode rdf:type owl:ObjectProperty ;
            rdfs:comment "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action."@en ;
            rdfs:isDefinedBy <https://w3id.org/refract> ;
            rdfs:label "source node"@en .


###  https://w3id.org/refract#sourceOnClass
:sourceOnClass rdf:type owl:ObjectProperty ;
               rdfs:comment "The URI of the filler class in a qualified cardinality restriction in the source ontology, used to uniquely identify the restriction when a class has multiple cardinality restrictions on the same property. If omitted, the restriction is assumed to be unqualified."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "source on class"@en .


###  https://w3id.org/refract#sourceParent
:sourceParent rdf:type owl:ObjectProperty ;
              rdfs:comment "The URI of an existing parent class or property of an ontology element, used to identify the specific superclass or super-property assertion to be changed or deleted. If omitted, the algorithm assumes there is only one superclass or super-property assertion."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "source parent"@en .


###  https://w3id.org/refract#sourceProperty
:sourceProperty rdf:type owl:ObjectProperty ;
                rdfs:comment "The URI of the property that a restriction or axiom is applied to in the source ontology, used to identify the specific restriction or axiom to be deleted."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "source property"@en .


###  https://w3id.org/refract#startingNode
:startingNode rdf:type owl:ObjectProperty ;
              rdfs:comment "The URI of the root class from which a localisation process begins. If omitted, the localisation applies to the entire source ontology."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "starting node"@en .


###  https://w3id.org/refract#targetAnnotation
:targetAnnotation rdf:type owl:ObjectProperty ;
                  rdfs:comment "The URI of an annotation property to be added to an ontology element as part of a refactoring action."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "target annotation"@en .


###  https://w3id.org/refract#targetConcept
:targetConcept rdf:type owl:ObjectProperty ;
               rdfs:comment "16-06-2026: Possibly needs to be removed."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "target concept"@en .


###  https://w3id.org/refract#targetDataType
:targetDataType rdf:type owl:ObjectProperty ;
                rdfs:comment "Specifies the datatype of a value in a refactoring action, for example an annotation value or a data property value. The value must be a URI representing a valid XSD, RDF, or OWL datatype."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "target datatype"@en .


###  https://w3id.org/refract#targetIdentifier
:targetIdentifier rdf:type owl:ObjectProperty ;
                  rdfs:comment "The URI (or fragment identifier) of an ontology element. This parameter is used when the element does not yet exist in the target ontology, for example when creating a new element. It is also used to specify the new URI when renaming an existing element."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "target identifier"@en .


###  https://w3id.org/refract#targetInstanceOf
:targetInstanceOf rdf:type owl:ObjectProperty ;
                  rdfs:comment "The URI of the class that a new named individual is declared as an instance of, as part of an 'add instance' refactoring action. Multiple classes may be specified."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "target instance of"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :targetInstanceOf ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "The URI of the class that a new named individual is declared as an instance of, as part of an 'add instance' refactoring action. Multiple classes may be specified."@en ;
   rdfs:seeAlso :AddInstance
 ] .


###  https://w3id.org/refract#targetMembers
:targetMembers rdf:type owl:ObjectProperty ;
               rdfs:comment "A list of URIs representing the members of an ordered or unordered group used in a refactoring action, for example the classes in a union or intersection, or the properties in a sub-property chain."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "target members"@en .


###  https://w3id.org/refract#targetNode
:targetNode rdf:type owl:ObjectProperty ;
            rdfs:comment "The URI of an ontology element that already exists in the target ontology, or has been created during the transformation process, and is then referenced by a refactoring action during the same transformation process."@en ;
            rdfs:isDefinedBy <https://w3id.org/refract> ;
            rdfs:label "target node"@en .


###  https://w3id.org/refract#targetObject
:targetObject rdf:type owl:ObjectProperty ;
              rdfs:comment "The URI of the property used in a refactoring action, for example the property of a restriction, axiom, or instance property assertion."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "target object"@en .


###  https://w3id.org/refract#targetObjectValue
:targetObjectValue rdf:type owl:ObjectProperty ;
                   rdfs:comment "The URI of the value used in a refactoring action, for example the filler class of a restriction or the value of an instance property assertion."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "target object value"@en .


###  https://w3id.org/refract#targetOntologyURI
:targetOntologyURI rdf:type owl:ObjectProperty ;
                   rdfs:comment "The URI of the target ontology produced by a transformation or localisation process."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "target ontology URI"@en .


###  https://w3id.org/refract#targetParent
:targetParent rdf:type owl:ObjectProperty ;
              rdfs:comment "The URI of the parent class or property of an ontology element that is to be created by a refactoring action. If omitted, the element will be a subclass of owl:Thing (for classes) or a sub-property of the top object, data, or annotation property (for properties)."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "target parent"@en .


###  https://w3id.org/refract#targetViewpoint
:targetViewpoint rdf:type owl:ObjectProperty ;
                 rdfs:comment "The URI of the viewpoint that the target ontology represents, as defined in the MULTI ontology."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "target viewpoint"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :targetViewpoint ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "The URI of the viewpoint that the target ontology represents, as defined in the MULTI ontology."@en ;
   rdfs:seeAlso <https://semanticweb.tools/ont/multi>
 ] .


###  https://w3id.org/refract#transformationSource
:transformationSource rdf:type owl:ObjectProperty ;
                      rdfs:comment "The URI of the source ontology that is being transformed, refactored, evolved, or localised."@en ;
                      rdfs:isDefinedBy <https://w3id.org/refract> ;
                      rdfs:label "transformation source"@en .


###  https://w3id.org/refract#transformationTarget
:transformationTarget rdf:type owl:ObjectProperty ;
                      rdfs:comment "11-06-2026: Possibly needs to be removed."@en ;
                      rdfs:isDefinedBy <https://w3id.org/refract> ;
                      rdfs:label "transformation target"@en .


###  https://w3id.org/refract#transformationType
:transformationType rdf:type owl:ObjectProperty ;
                    rdfs:comment "Specifies the type of transformation process described by the Transformation Manifest File. The value must be one of: 'Ontology refactoring process', 'Ontology evolution process', 'Ontology transformation process', or 'Ontology localisation process'."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "transformation type"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :transformationType ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Specifies the type of transformation process described by the Transformation Manifest File. The value must be one of: 'Ontology refactoring process', 'Ontology evolution process', 'Ontology transformation process', or 'Ontology localisation process'."@en ;
   rdfs:seeAlso :TransformationProcess
 ] .


###  https://w3id.org/refract#versionManifest
:versionManifest rdf:type owl:ObjectProperty ;
                 rdfs:comment "Links a manifest to its version metadata, specified as an instance of 'Version'."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "version manifest"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :versionManifest ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Links a manifest to its version metadata, specified as an instance of 'Version'."@en ;
   rdfs:seeAlso :Version
 ] .


###  https://w3id.org/refract#versionPrevious
:versionPrevious rdf:type owl:ObjectProperty ;
                 rdfs:comment "Links a version of a Transformation Manifest File to its previous version. If this is the first version of the TMF, the value should be 'No previous version'."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "previous version"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :versionPrevious ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Links a version of a Transformation Manifest File to its previous version. If this is the first version of the TMF, the value should be 'No previous version'."@en ;
   rdfs:seeAlso :NoPreviousVersion
 ] .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/date
dcterms:date rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:DatatypeProperty ;
              rdfs:isDefinedBy "http://purl.org/dc/terms/" ;
              rdfs:label "title"@en .


###  https://w3id.org/refract#URI
:URI rdf:type owl:DatatypeProperty ;
     rdfs:comment "A URI value associated with a refactoring action, expressed as an xsd:anyURI literal."@en ;
     rdfs:isDefinedBy <https://w3id.org/refract> ;
     rdfs:label "URI"@en .


###  https://w3id.org/refract#actionSequence
:actionSequence rdf:type owl:DatatypeProperty ;
                rdfs:comment "An integer value that specifies the execution order of an atomic action within a composite action. If two or more actions have the same sequence number, the transformation algorithm resolves the order by their order of appearance in the Transformation Manifest File."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "action sequence"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :actionSequence ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "An integer value that specifies the execution order of an atomic action within a composite action. If two or more actions have the same sequence number, the transformation algorithm resolves the order by their order of appearance in the Transformation Manifest File."@en ;
   rdfs:seeAlso :CompositeAction
 ] .


###  https://w3id.org/refract#changeLog
:changeLog rdf:type owl:DatatypeProperty ;
           rdfs:comment "11-06-2026: Not used at the moment. Planned for future work."@en ;
           rdfs:isDefinedBy <https://w3id.org/refract> ;
           rdfs:label "change log"@en .


###  https://w3id.org/refract#includeSeeAlso
:includeSeeAlso rdf:type owl:DatatypeProperty ;
                rdfs:comment "Specifies whether the algorithm should add an rdfs:seeAlso reference to the successor class on the deprecated class. Accepts \"true\" or \"false\". If omitted, defaults to \"true\"."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "include 'see also'"@en .


###  https://w3id.org/refract#targetAnnotationValue
:targetAnnotationValue rdf:type owl:DatatypeProperty ;
                       rdfs:comment "The value of an annotation to be added to an ontology element as part of a refactoring action, expressed as a plain string. The datatype of the value is specified by 'target datatype' for catch-all annotation actions, or is implicit in the dedicated annotation action type."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "target annotation value"@en .


###  https://w3id.org/refract#targetLabel
:targetLabel rdf:type owl:DatatypeProperty ;
             rdfs:comment "A plain string label for an ontology element that is to be created by a refactoring action. The language of the label is specified by 'target language tag'. To add additional language-tagged strings, use the annotation action 'Add annotation - lang string'."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "target label"@en .


###  https://w3id.org/refract#targetLanguageTag
:targetLanguageTag rdf:type owl:DatatypeProperty ;
                   rdfs:comment "A language tag expressed as a plain string, conforming to ISO 639 or BCP 47 (e.g. \"en-za\", \"fr\"). For add actions, this specifies the language tag of the new annotation value or label. For change annotation actions, this is used to identify the specific annotation to be changed where more than one annotation exists for the same annotation property; it is not used to change the language tag itself. To change a language tag, use 'target language tag new'."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "target language tag"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :targetLanguageTag ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "A language tag expressed as a plain string, conforming to ISO 639 or BCP 47 (e.g. \"en-za\", \"fr\"). For add actions, this specifies the language tag of the new annotation value or label. For change annotation actions, this is used to identify the specific annotation to be changed where more than one annotation exists for the same annotation property; it is not used to change the language tag itself. To change a language tag, use 'target language tag new'."@en ;
   rdfs:seeAlso <https://www.rfc-editor.org/info/bcp47/>
 ] .


###  https://w3id.org/refract#targetLanguageTagNew
:targetLanguageTagNew rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:comment "The new language tag for a language-tagged string annotation, expressed as a plain string and conforming to BCP 47 (e.g. \"en\", \"en-ZA\"). Used in 'Change annotation - langString' to replace the existing language tag identified by 'target language tag'."@en ;
                      rdfs:isDefinedBy <https://w3id.org/refract> ;
                      rdfs:label "target language tag - new"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :targetLanguageTagNew ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "The new language tag for a language-tagged string annotation, expressed as a plain string and conforming to BCP 47 (e.g. \"en\", \"en-ZA\"). Used in 'Change annotation - langString' to replace the existing language tag identified by 'target language tag'."@en ;
   rdfs:seeAlso <https://www.rfc-editor.org/info/bcp47/>
 ] .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class ;
              rdfs:subClassOf rdfs:Class ;
              rdfs:comment "An activity is something that occurs over a period of time and acts upon or with entities; it may include consuming, processing, transforming, modifying, relocating, using, or generating entities."@en ;
              rdfs:isDefinedBy "http://www.w3.org/ns/prov#" ;
              rdfs:label "Activity"@en .


###  https://w3id.org/refract#AddAnnotation
:AddAnnotation rdf:type owl:Class ;
               rdfs:subClassOf :AnnotationAction ;
               rdfs:comment "A catch-all annotation action that adds an annotation to an ontology element. For language-tagged string annotations, use fract:AddAnnotationLangString instead."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "Add annotation"@en ;
               :exampleTMF <https://semanticweb.tools/rdf/tmf/AddAnnotation.ttl> ;
               :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target datatype', a URI is expected specifying the XSD, RDF, or OWL datatype of the annotation value. The algorithm will cast the value to the specified datatype in the target ontology. For language-tagged string annotations, use fract:AddAnnotationLangString instead."@en ;
               :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddAnnotation.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddAnnotation ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target datatype', a URI is expected specifying the XSD, RDF, or OWL datatype of the annotation value. The algorithm will cast the value to the specified datatype in the target ontology. For language-tagged string annotations, use fract:AddAnnotationLangString instead."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :targetAnnotation ,
                         :targetAnnotationValue ,
                         :targetDataType
 ] .


###  https://w3id.org/refract#AddAnnotationLangString
:AddAnnotationLangString rdf:type owl:Class ;
                         rdfs:subClassOf :AnnotationAction ;
                         rdfs:comment "An annotation action that adds a language-tagged string annotation to an ontology element."@en ;
                         rdfs:isDefinedBy <https://w3id.org/refract> ;
                         rdfs:label "Add annotation - langString"@en ;
                         :exampleTMF <https://semanticweb.tools/rdf/tmf/AddAnnotationLangString.ttl> ;
                         :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\"). The algorithm will cast the value to an rdf:langString in the target ontology."@en ;
                         :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddAnnotationLangString.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddAnnotationLangString ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\"). The algorithm will cast the value to an rdf:langString in the target ontology."@en ;
   rdfs:comment :targetLanguageTag ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :targetAnnotation ,
                         :targetAnnotationValue
 ] .


###  https://w3id.org/refract#AddAnnotationProperty
:AddAnnotationProperty rdf:type owl:Class ;
                       rdfs:subClassOf :StructuralAction ;
                       rdfs:comment "A structural action that adds an annotation property to the ontology."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Add annotation property"@en ;
                       :exampleTMF <https://semanticweb.tools/rdf/tmf/AddAnnotationProperty.ttl> ;
                       :hasParameters "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new annotation property is declared as a sub-property of the given parent; otherwise no explicit parent assertion is made."@en ;
                       :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddAnnotationProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddAnnotationProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new annotation property is declared as a sub-property of the given parent; otherwise no explicit parent assertion is made."@en ;
   rdfs:comment :targetLanguageTag ;
   :hasOptionalParameter :targetParent ;
   :hasRequiredParameter :targetIdentifier ,
                         :targetLabel
 ] .


###  https://w3id.org/refract#AddClass
:AddClass rdf:type owl:Class ;
          rdfs:subClassOf :SemanticAction ,
                          :StructuralAction ;
          rdfs:comment "A structural and semantic action that adds a class to the ontology."@en ;
          rdfs:isDefinedBy <https://w3id.org/refract> ;
          rdfs:label "Add class"@en ;
          :exampleTMF <https://semanticweb.tools/rdf/tmf/AddClass.ttl> ;
          :hasParameters "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new class is declared as a subclass of the given parent; otherwise it will by default be a subclass of owl:Thing, with no explicit assertion thereof. Multiple parent URIs may be specified."@en ;
          :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddClass.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddClass ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new class is declared as a subclass of the given parent; otherwise it will by default be a subclass of owl:Thing, with no explicit assertion thereof. Multiple parent URIs may be specified."@en ;
   :hasOptionalParameter :actionSequence ,
                         :targetParent ;
   :hasRequiredParameter :targetIdentifier ,
                         :targetLabel ,
                         :targetLanguageTag
 ] .


###  https://w3id.org/refract#AddCommentForDeprecation
:AddCommentForDeprecation rdf:type owl:Class ;
                          rdfs:subClassOf :AnnotationAction ;
                          rdfs:comment "An annotation action that adds a deprecation comment and optionally a 'see also' reference to the deprecated class as part of a 'Deprecate class with successor class' composite action. If 'target annotation value' is omitted, the algorithm generates the comment from a template. This action is not intended to be used standalone."@en ;
                          rdfs:isDefinedBy <https://w3id.org/refract> ;
                          rdfs:label "Add comment for deprecation"@en ;
                          :exampleTMF <https://semanticweb.tools/rdf/tmf/AddCommentForDeprecation.ttl> ;
                          :hasParameters "All parameters are optional. For 'target annotation', the URI of an annotation property is expected; if omitted, defaults to rdfs:comment. For 'target annotation value', a plain string is expected specifying a custom deprecation comment; if omitted, the algorithm generates a comment from one of two templates depending on whether a date can be derived from the composite action: \"Deprecated as of {date}. Use {successor} instead.\" or \"Deprecated. Use {successor} instead.\" For 'target language tag', a plain string conforming to BCP 47 is expected; required if 'target annotation value' is specified. For 'include 'see also'', \"true\" or \"false\" is expected; if omitted, defaults to \"true\", adding an rdfs:seeAlso reference to the successor class. For 'action sequence', an integer is expected specifying the execution order of this action within the composite action."@en ;
                          :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddCommentForDeprecation.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddCommentForDeprecation ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "An annotation action that adds a deprecation comment and optionally a 'see also' reference to the deprecated class as part of a 'Deprecate class with successor class' composite action. If 'target annotation value' is omitted, the algorithm generates the comment from a template. This action is not intended to be used standalone."@en ;
   rdfs:seeAlso :DeprecateClassWithSuccessor
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddCommentForDeprecation ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "All parameters are optional. For 'target annotation', the URI of an annotation property is expected; if omitted, defaults to rdfs:comment. For 'target annotation value', a plain string is expected specifying a custom deprecation comment; if omitted, the algorithm generates a comment from one of two templates depending on whether a date can be derived from the composite action: \"Deprecated as of {date}. Use {successor} instead.\" or \"Deprecated. Use {successor} instead.\" For 'target language tag', a plain string conforming to BCP 47 is expected; required if 'target annotation value' is specified. For 'include 'see also'', \"true\" or \"false\" is expected; if omitted, defaults to \"true\", adding an rdfs:seeAlso reference to the successor class. For 'action sequence', an integer is expected specifying the execution order of this action within the composite action."@en ;
   :hasOptionalParameter :actionSequence ,
                         :targetAnnotationValue ,
                         :targetLanguageTag ;
   :hasOptionalParameterWithFallback :includeSeeAlso ,
                                     :targetAnnotation
 ] .


###  https://w3id.org/refract#AddDataProperty
:AddDataProperty rdf:type owl:Class ;
                 rdfs:subClassOf :StructuralAction ;
                 rdfs:comment "A structural action that adds a data property to the ontology."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "Add data property"@en ;
                 :exampleTMF <https://semanticweb.tools/rdf/tmf/AddDataProperty.ttl> ;
                 :hasParameters "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new data property is declared as a sub-property of the given parent; otherwise it will by default be a sub-property of owl:topDataProperty, with no explicit assertion thereof."@en ;
                 :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddDataProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddDataProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new data property is declared as a sub-property of the given parent; otherwise it will by default be a sub-property of owl:topDataProperty, with no explicit assertion thereof."@en ;
   :hasOptionalParameter :targetParent ;
   :hasRequiredParameter :targetIdentifier ,
                         :targetLabel ,
                         :targetLanguageTag
 ] .


###  https://w3id.org/refract#AddEquivalentClassSet
:AddEquivalentClassSet rdf:type owl:Class ;
                       rdfs:subClassOf :SemanticAction ;
                       rdfs:comment "A semantic action that adds a set-based equivalent class assertion to a class in the ontology, using either an owl:unionOf or owl:intersectionOf property. For simple equivalent class assertions, use 'Add semantic axiom' instead."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Add equivalent class (set-based)"@en ;
                       :exampleTMF <https://semanticweb.tools/rdf/tmf/AddEquivalentClassSet.ttl> ;
                       :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target members', a list of class URIs is expected. For 'set type', either owl:unionOf or owl:intersectionOf is expected."@en ;
                       :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddEquivalentClassSet.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddEquivalentClassSet ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target members', a list of class URIs is expected. For 'set type', either owl:unionOf or owl:intersectionOf is expected."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :setType ,
                         :targetMembers
 ] .


###  https://w3id.org/refract#AddInstance
:AddInstance rdf:type owl:Class ;
             rdfs:subClassOf :SemanticAction ;
             rdfs:comment "A semantic action that adds a named individual to the ontology as an instance of a specified class."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "Add instance"@en ;
             :exampleTMF <https://semanticweb.tools/rdf/tmf/AddInstance.ttl> ;
             :hasParameters "For 'target identifier', a URI is expected specifying the new individual. For 'target instance of', a URI is expected specifying the class the individual is an instance of. Multiple classes may be specified. For 'target label', a plain string is expected. For 'target language tag', a plain string conforming to BCP 47 is expected (e.g. \"en-za\", \"fr\")."@en ;
             :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddInstance.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddInstance ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'target identifier', a URI is expected specifying the new individual. For 'target instance of', a URI is expected specifying the class the individual is an instance of. Multiple classes may be specified. For 'target label', a plain string is expected. For 'target language tag', a plain string conforming to BCP 47 is expected (e.g. \"en-za\", \"fr\")."@en ;
   :hasRequiredParameter :targetIdentifier ,
                         :targetInstanceOf ,
                         :targetLabel ,
                         :targetLanguageTag
 ] .


###  https://w3id.org/refract#AddInstancePropertyAssertion
:AddInstancePropertyAssertion rdf:type owl:Class ;
                              rdfs:subClassOf :SemanticAction ;
                              rdfs:comment "A semantic action that adds an object or data property assertion to a named individual in the ontology."@en ;
                              rdfs:isDefinedBy <https://w3id.org/refract> ;
                              rdfs:label "Add instance property assertion"@en ;
                              :exampleTMF <https://semanticweb.tools/rdf/tmf/AddInstancePropertyAssertion.ttl> ;
                              :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided, specifying the named individual. For 'target object', a URI is expected specifying the property. For 'target object value', a URI is expected specifying the value of the assertion. For 'property type', either owl:ObjectProperty or owl:DatatypeProperty is expected."@en ;
                              :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddInstancePropertyAssertion.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddInstancePropertyAssertion ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided, specifying the named individual. For 'target object', a URI is expected specifying the property. For 'target object value', a URI is expected specifying the value of the assertion. For 'property type', either owl:ObjectProperty or owl:DatatypeProperty is expected."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :propertyType ,
                         :targetObject ,
                         :targetObjectValue
 ] .


###  https://w3id.org/refract#AddNamespacePrefix
:AddNamespacePrefix rdf:type owl:Class ;
                    rdfs:subClassOf :GlobalAction ;
                    rdfs:comment "A global refactoring action that adds a namespace prefix declaration to an ontology."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "Add namespace prefix"@en ;
                    :exampleTMF <https://semanticweb.tools/rdf/tmf/AddNamespacePrefix.ttl> ;
                    :hasParameters "For 'prefix', a plain string is expected specifying the prefix name (e.g. \"skos\"). For 'namespace', a URI is expected specifying the namespace (e.g. http://www.w3.org/2004/02/skos/core#)."@en ;
                    :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddNamespacePrefix.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddNamespacePrefix ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'prefix', a plain string is expected specifying the prefix name (e.g. \"skos\"). For 'namespace', a URI is expected specifying the namespace (e.g. http://www.w3.org/2004/02/skos/core#)."@en ;
   :hasRequiredParameter <http://www.w3.org/ns/shacl#namespace> ,
                         <http://www.w3.org/ns/shacl#prefix>
 ] .


###  https://w3id.org/refract#AddObjectProperty
:AddObjectProperty rdf:type owl:Class ;
                   rdfs:subClassOf :StructuralAction ;
                   rdfs:comment "A structural action that adds an object property to the ontology."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "Add object property"@en ;
                   :exampleTMF <https://semanticweb.tools/rdf/tmf/AddObjectProperty.ttl> ;
                   :hasParameters "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new object property is declared as a sub-property of the given parent; otherwise it will by default be a sub-property of owl:topObjectProperty, with no explicit assertion thereof."@en ;
                   :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddObjectProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddObjectProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'target identifier' and 'target parent', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If 'target parent' is specified, the new object property is declared as a sub-property of the given parent; otherwise it will by default be a sub-property of owl:topObjectProperty, with no explicit assertion thereof."@en ;
   :hasOptionalParameter :targetParent ;
   :hasRequiredParameter :targetIdentifier ,
                         :targetLabel ,
                         :targetLanguageTag
 ] .


###  https://w3id.org/refract#AddPropertyDomainRange
:AddPropertyDomainRange rdf:type owl:Class ;
                        rdfs:subClassOf :SemanticAction ;
                        rdfs:comment "A semantic action that adds a domain or range assertion to an object or data property in the ontology."@en ;
                        rdfs:isDefinedBy <https://w3id.org/refract> ;
                        rdfs:label "Add property domain or range assertion"@en ;
                        :exampleTMF <https://semanticweb.tools/rdf/tmf/AddPropertyDomainRange.ttl> ;
                        :hasParameters "For 'source node', a URI is expected specifying the property. For 'target node', a URI is expected specifying the class to be added as the domain or range. For 'axiom type', either rdfs:domain or rdfs:range is expected. For 'property type', either owl:ObjectProperty or owl:DatatypeProperty is expected."@en ;
                        :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddPropertyDomainRange.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddPropertyDomainRange ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the property. For 'target node', a URI is expected specifying the class to be added as the domain or range. For 'axiom type', either rdfs:domain or rdfs:range is expected. For 'property type', either owl:ObjectProperty or owl:DatatypeProperty is expected."@en ;
   :hasRequiredParameter :axiomType ,
                         :propertyType ,
                         :sourceNode ,
                         :targetNode
 ] .


###  https://w3id.org/refract#AddPropertyRestriction
:AddPropertyRestriction rdf:type owl:Class ;
                        rdfs:subClassOf :SemanticAction ;
                        rdfs:comment "A semantic action that adds an existential or universal property restriction to a class in the ontology, using either an object or data property."@en ;
                        rdfs:isDefinedBy <https://w3id.org/refract> ;
                        rdfs:label "Add property restriction"@en ;
                        :exampleTMF <https://semanticweb.tools/rdf/tmf/AddPropertyRestriction.ttl> ;
                        :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target object', a URI is expected specifying the property of the restriction. For 'target object value', a URI is expected specifying the filler class or datatype of the restriction. For 'restriction type', either owl:someValuesFrom (existential) or owl:allValuesFrom (universal) is expected. For 'property type', either owl:ObjectProperty or owl:DatatypeProperty is expected."@en ;
                        :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddPropertyRestriction.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddPropertyRestriction ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target object', a URI is expected specifying the property of the restriction. For 'target object value', a URI is expected specifying the filler class or datatype of the restriction. For 'restriction type', either owl:someValuesFrom (existential) or owl:allValuesFrom (universal) is expected. For 'property type', either owl:ObjectProperty or owl:DatatypeProperty is expected."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :propertyType ,
                         :restrictionType ,
                         :targetObject ,
                         :targetObjectValue
 ] .


###  https://w3id.org/refract#AddSemanticAxiom
:AddSemanticAxiom rdf:type owl:Class ;
                  rdfs:subClassOf :SemanticAction ;
                  rdfs:comment "A catch-all semantic action that adds a binary semantic axiom between two ontology elements. Use a dedicated action where one exists for the specific axiom type."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Add semantic axiom"@en ;
                  :exampleTMF <https://semanticweb.tools/rdf/tmf/AddSemanticAxiom.ttl> ;
                  :hasParameters "For 'source node', a URI is expected specifying the subject of the axiom. For 'target node', a URI is expected specifying the object of the axiom. For 'axiom type', a URI is expected specifying the OWL or RDF axiom type to be added."@en ;
                  :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddSemanticAxiom.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddSemanticAxiom ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the subject of the axiom. For 'target node', a URI is expected specifying the object of the axiom. For 'axiom type', a URI is expected specifying the OWL or RDF axiom type to be added."@en ;
   :hasRequiredParameter :axiomType ,
                         :sourceNode ,
                         :targetNode
 ] .


###  https://w3id.org/refract#AddSemanticAxiomUnary
:AddSemanticAxiomUnary rdf:type owl:Class ;
                       rdfs:subClassOf :SemanticAction ;
                       rdfs:comment "A catch-all semantic action that adds a unary semantic axiom to a single ontology element, such as a property characteristic. Use a dedicated action where one exists for the specific axiom type."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Add semantic axiom - unary"@en ;
                       :exampleTMF <https://semanticweb.tools/rdf/tmf/AddSemanticAxiomUnary.ttl> ;
                       :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'axiom type', a URI is expected specifying the OWL or RDF axiom type to be added."@en ;
                       :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddSemanticAxiomUnary.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddSemanticAxiomUnary ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'axiom type', a URI is expected specifying the OWL or RDF axiom type to be added."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :axiomType
 ] .


###  https://w3id.org/refract#AddSubPropertyChainOf
:AddSubPropertyChainOf rdf:type owl:Class ;
                       rdfs:subClassOf :SemanticAction ;
                       rdfs:comment "A semantic action that adds a sub-property chain axiom to an object property in the ontology."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Add sub-property chain axiom"@en ;
                       :exampleTMF <https://semanticweb.tools/rdf/tmf/AddSubPropertyChainOf.ttl> ;
                       :hasParameters "For 'source node', a URI is expected specifying the property that is the super-property of the chain. For 'target members', a list of property URIs is expected specifying the chain of properties."@en ;
                       :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddSubPropertyChainOf.ttl> .

