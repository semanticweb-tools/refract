   :hasRequiredParameter :sourceNode ,
                         :targetMembers
 ] .


###  https://w3id.org/refract#AddSuperclassAssertion
:AddSuperclassAssertion rdf:type owl:Class ;
                        rdfs:subClassOf :SemanticAction ;
                        rdfs:comment "A semantic action that adds a superclass assertion to a class in the ontology."@en ;
                        rdfs:isDefinedBy <https://w3id.org/refract> ;
                        rdfs:label "Add superclass assertion"@en ;
                        :exampleTMF <https://semanticweb.tools/rdf/tmf/AddSuperclassAssertion.ttl> ;
                        :hasParameters "For 'source node', a URI is expected specifying the class. For 'target parent', a URI is expected specifying the superclass to be asserted."@en ;
                        :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeAddSuperclassAssertion.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AddSuperclassAssertion ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the class. For 'target parent', a URI is expected specifying the superclass to be asserted."@en ;
   :hasRequiredParameter :sourceNode ,
                         :targetParent
 ] .


###  https://w3id.org/refract#AlgorithmCheck
:AlgorithmCheck rdf:type owl:Class ;
                rdfs:subClassOf rdfs:Resource ;
                rdfs:comment "A class representing the behaviour of the transformation algorithm when a pre-processing check condition is met. Subclasses of this class represent specific categories of pre-processing checks."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "Algorithm check"@en .


###  https://w3id.org/refract#AlgorithmCheckAnnotation
:AlgorithmCheckAnnotation rdf:type owl:Class ;
                          rdfs:subClassOf :AlgorithmCheck ;
                          rdfs:comment "A class representing the behaviour of the transformation algorithm when an existing annotation is not found during pre-processing for a change annotation action. One of three behaviours may be specified: 'If false - stop', 'If false - ignore', or 'If false - add'."@en ;
                          rdfs:isDefinedBy <https://w3id.org/refract> ;
                          rdfs:label "Algorithm check - annotation"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AlgorithmCheckAnnotation ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "A class representing the behaviour of the transformation algorithm when an existing annotation is not found during pre-processing for a change annotation action. One of three behaviours may be specified: 'If false - stop', 'If false - ignore', or 'If false - add'."@en ;
   rdfs:seeAlso :AnnotationAction ,
                :checkForAnnotation
 ] .


###  https://w3id.org/refract#AlgorithmCheckAssertion
:AlgorithmCheckAssertion rdf:type owl:Class ;
                         rdfs:subClassOf :AlgorithmCheck ;
                         rdfs:comment "A class representing the behaviour of the transformation algorithm when existing assertions are found during pre-processing for an element that is to be deleted. An element can be a class, object property, data property, or annotation property. One of three behaviours may be specified: stop, ignore, or delete."@en ;
                         rdfs:isDefinedBy <https://w3id.org/refract> ;
                         rdfs:label "Algorithm check - assertion"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AlgorithmCheckAssertion ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "A class representing the behaviour of the transformation algorithm when existing assertions are found during pre-processing for an element that is to be deleted. An element can be a class, object property, data property, or annotation property. One of three behaviours may be specified: stop, ignore, or delete."@en ;
   rdfs:seeAlso :StructuralAction ,
                :checkForAssertion
 ] .


###  https://w3id.org/refract#AnnotationAction
:AnnotationAction rdf:type owl:Class ;
                  rdfs:subClassOf :AtomicAction ;
                  rdfs:comment "An atomic action that adds, modifies, or removes an annotation on an ontology element using an existing annotation property. Annotations are ignored by reasoners and do not affect the structure or semantic meaning of the ontology. To add or delete an annotation property, see 'Structural action'."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Annotation action"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :AnnotationAction ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "An atomic action that adds, modifies, or removes an annotation on an ontology element using an existing annotation property. Annotations are ignored by reasoners and do not affect the structure or semantic meaning of the ontology. To add or delete an annotation property, see 'Structural action'."@en ;
   rdfs:seeAlso :StructuralAction
 ] .


###  https://w3id.org/refract#AtomicAction
:AtomicAction rdf:type owl:Class ;
              rdfs:subClassOf :LocalAction ;
              rdfs:comment "A micro-level local refactoring action that cannot be decomposed into smaller refactoring actions. An atomic action may operate on a single ontology element, a set of ontology elements, or a concept represented by one or more ontology elements."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "Atomic action"@en .


###  https://w3id.org/refract#ChangeAnnotation
:ChangeAnnotation rdf:type owl:Class ;
                  rdfs:subClassOf :AnnotationAction ;
                  rdfs:comment "An annotation action that changes both the value and the datatype of an existing annotation on an ontology element."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Change annotation"@en ;
                  :exampleTMF <https://semanticweb.tools/rdf/tmf/ChangeAnnotation.ttl> ;
                  :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target datatype', a URI is expected specifying the XSD, RDF, or OWL datatype of the new annotation value. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\", \"fr\"); this is used to identify the specific annotation to be changed, not to change the language tag itself. The algorithm performs two pre-processing checks: first, whether the annotation exists; second, whether more than one annotation exists for the same annotation property and language tag combination. The behaviour for each check is determined by the value of 'check for annotation'. If omitted, the algorithm defaults to 'If false - add' for the first check and 'If multiple - ignore' for the second check."@en ;
                  :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeChangeAnnotation.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ChangeAnnotation ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target datatype', a URI is expected specifying the XSD, RDF, or OWL datatype of the new annotation value. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\", \"fr\"); this is used to identify the specific annotation to be changed, not to change the language tag itself. The algorithm performs two pre-processing checks: first, whether the annotation exists; second, whether more than one annotation exists for the same annotation property and language tag combination. The behaviour for each check is determined by the value of 'check for annotation'. If omitted, the algorithm defaults to 'If false - add' for the first check and 'If multiple - ignore' for the second check."@en ;
   :hasOptionalParameter :targetLanguageTag ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasOptionalParameterWithFallback :checkForAnnotation ;
   :hasRequiredParameter :targetAnnotation ,
                         :targetAnnotationValue ,
                         :targetDataType
 ] .


###  https://w3id.org/refract#ChangeAnnotationLangString
:ChangeAnnotationLangString rdf:type owl:Class ;
                            rdfs:subClassOf :AnnotationAction ;
                            rdfs:comment "An annotation action that changes the value and/or language tag of an existing language-tagged string annotation on an ontology element."@en ;
                            rdfs:isDefinedBy <https://w3id.org/refract> ;
                            rdfs:label "Change annotation - langString"@en ;
                            :exampleTMF <https://semanticweb.tools/rdf/tmf/ChangeAnnotationLangString.ttl> ;
                            :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en\", \"fr\"); this is used to identify the specific annotation to be changed, not to change the language tag itself. At least one of 'target annotation value' or 'target language tag - new' must be specified. The algorithm performs two pre-processing checks: first, whether the annotation exists; second, whether more than one annotation exists for the same annotation property and language tag combination. The behaviour for each check is determined by the value of 'check for annotation'. If omitted, the algorithm defaults to 'If false - add' for the first check and 'If multiple - ignore' for the second check."@en ;
                            :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeChangeAnnotationLangString.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ChangeAnnotationLangString ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en\", \"fr\"); this is used to identify the specific annotation to be changed, not to change the language tag itself. At least one of 'target annotation value' or 'target language tag - new' must be specified. The algorithm performs two pre-processing checks: first, whether the annotation exists; second, whether more than one annotation exists for the same annotation property and language tag combination. The behaviour for each check is determined by the value of 'check for annotation'. If omitted, the algorithm defaults to 'If false - add' for the first check and 'If multiple - ignore' for the second check."@en ;
   :hasOptionalParameter :targetLanguageTag ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetAnnotationValue ,
                                       :targetLanguageTagNew ,
                                       :targetNode ;
   :hasOptionalParameterWithFallback :checkForAnnotation ;
   :hasRequiredParameter :targetAnnotation
 ] .


###  https://w3id.org/refract#ChangeAnnotationValue
:ChangeAnnotationValue rdf:type owl:Class ;
                       rdfs:subClassOf :AnnotationAction ;
                       rdfs:comment "An annotation action that changes the value of an existing annotation on an ontology element, without changing the datatype. If a language tag is specified, it is used to identify the specific annotation to be changed, not to change the language tag itself."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Change annotation value"@en ;
                       :exampleTMF <https://semanticweb.tools/rdf/tmf/ChangeAnnotationValue.ttl> ;
                       :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\"); if omitted and more than one annotation is found for the same annotation property, the behaviour is determined by 'If multiple - stop' or 'If multiple - ignore'. The algorithm performs two pre-processing checks: first, whether the annotation exists; second, whether more than one annotation exists for the same annotation property and language tag combination. The behaviour for each check is determined by the value of 'check for annotation'. If omitted, the algorithm defaults to 'If false - add' for the first check and 'If multiple - ignore' for the second check."@en ;
                       :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeChangeAnnotationValue.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ChangeAnnotationValue ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target annotation value', a plain string is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\"); if omitted and more than one annotation is found for the same annotation property, the behaviour is determined by 'If multiple - stop' or 'If multiple - ignore'. The algorithm performs two pre-processing checks: first, whether the annotation exists; second, whether more than one annotation exists for the same annotation property and language tag combination. The behaviour for each check is determined by the value of 'check for annotation'. If omitted, the algorithm defaults to 'If false - add' for the first check and 'If multiple - ignore' for the second check."@en ;
   :hasOptionalParameter :targetLanguageTag ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasOptionalParameterWithFallback :checkForAnnotation ;
   :hasRequiredParameter :targetAnnotation ,
                         :targetAnnotationValue
 ] .


###  https://w3id.org/refract#ChangeInstanceAssertion
:ChangeInstanceAssertion rdf:type owl:Class ;
                         rdfs:subClassOf :SemanticAction ;
                         rdfs:comment "A semantic action that changes the class assertion of a named individual in the ontology."@en ;
                         rdfs:isDefinedBy <https://w3id.org/refract> ;
                         rdfs:label "Change instance assertion"@en ;
                         :exampleTMF <https://semanticweb.tools/rdf/tmf/ChangeInstanceAssertion.ttl> ;
                         :hasParameters "For 'source node', a URI is expected specifying the individual whose class assertion is to be changed. For 'target node', a URI is expected specifying the new class."@en ;
                         :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeChangeInstanceAssertion.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ChangeInstanceAssertion ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the individual whose class assertion is to be changed. For 'target node', a URI is expected specifying the new class."@en ;
   :hasRequiredParameter :sourceNode ,
                         :targetNode
 ] .


###  https://w3id.org/refract#ChangeSuperclassAssertion
:ChangeSuperclassAssertion rdf:type owl:Class ;
                           rdfs:subClassOf :SemanticAction ;
                           rdfs:comment "A semantic action that changes a superclass assertion for a class in the ontology."@en ;
                           rdfs:isDefinedBy <https://w3id.org/refract> ;
                           rdfs:label "Change superclass assertion"@en ;
                           :exampleTMF <https://semanticweb.tools/rdf/tmf/ChangeSuperclassAssertion.ttl> ;
                           :hasParameters "For 'source node', a URI is expected specifying the class. For 'source parent', a URI is expected specifying the existing superclass to be replaced. If omitted, the algorithm will change the first superclass assertion it finds without checking for additional superclass assertions. For 'target parent', a URI is expected specifying the new superclass."@en ;
                           :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeChangeSuperclassAssertion.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ChangeSuperclassAssertion ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the class. For 'source parent', a URI is expected specifying the existing superclass to be replaced. If omitted, the algorithm will change the first superclass assertion it finds without checking for additional superclass assertions. For 'target parent', a URI is expected specifying the new superclass."@en ;
   :hasOptionalParameter :sourceParent ;
   :hasRequiredParameter :sourceNode ,
                         :targetParent
 ] .


###  https://w3id.org/refract#CompositeAction
:CompositeAction rdf:type owl:Class ;
                 rdfs:subClassOf :LocalAction ;
                 rdfs:comment "A micro-level local refactoring action composed of two or more atomic actions that together represent a single logical change to an ontology."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "Composite action"@en .


###  https://w3id.org/refract#ConceptTransformation
:ConceptTransformation rdf:type owl:Class ;
                       rdfs:subClassOf rdfs:Class ;
                       rdfs:comment "A class representing the micro-level metadata of a concept transformation - the mapping between a source concept in the source ontology and its corresponding concept(s) in the target viewpoint. The semantic category of the transformation is specified using 'has semantic category'."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Concept transformation"@en .


###  https://w3id.org/refract#DeleteAnnotation
:DeleteAnnotation rdf:type owl:Class ;
                  rdfs:subClassOf :AnnotationAction ;
                  rdfs:comment "An annotation action that deletes an existing annotation from an ontology element. If a language tag is specified, only the annotation with the matching language tag is deleted."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Delete annotation"@en ;
                  :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteAnnotation.ttl> ;
                  :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\", \"fr\"); if specified, only the annotation with the matching language tag is deleted. If omitted, all annotations for the specified annotation property on the specified ontology element are deleted."@en ;
                  :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteAnnotation.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteAnnotation ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. For 'target annotation', the URI of an annotation property is expected. For 'target language tag', a language tag conforming to BCP 47 is expected (e.g. \"en-za\", \"fr\"); if specified, only the annotation with the matching language tag is deleted. If omitted, all annotations for the specified annotation property on the specified ontology element are deleted."@en ;
   :hasOptionalParameter :targetLanguageTag ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :targetAnnotation
 ] .


###  https://w3id.org/refract#DeleteAnnotationProperty
:DeleteAnnotationProperty rdf:type owl:Class ;
                          rdfs:subClassOf :StructuralAction ;
                          rdfs:comment "A structural action that deletes an annotation property from the source ontology."@en ;
                          rdfs:isDefinedBy <https://w3id.org/refract> ;
                          rdfs:label "Delete annotation property"@en ;
                          :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteAnnotationProperty.ttl> ;
                          :hasParameters "For 'source node', a URI is expected. If existing annotations for the annotation property are found during pre-processing (and there is no corresponding deletion refactoring action for those annotations), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - delete'."@en ;
                          :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteAnnotationProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteAnnotationProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected. If existing annotations for the annotation property are found during pre-processing (and there is no corresponding deletion refactoring action for those annotations), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - delete'."@en ;
   :hasOptionalParameterWithFallback :checkForAssertion ;
   :hasRequiredParameter :sourceNode
 ] .


###  https://w3id.org/refract#DeleteCardinalityRestriction
:DeleteCardinalityRestriction rdf:type owl:Class ;
                              rdfs:subClassOf :SemanticAction ;
                              rdfs:comment "A semantic action that deletes a cardinality restriction from a class in the ontology."@en ;
                              rdfs:isDefinedBy <https://w3id.org/refract> ;
                              rdfs:label "Delete cardinality restriction"@en ;
                              :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteCardinalityRestriction.ttl> ;
                              :hasParameters "For 'source node', a URI is expected specifying the class the restriction is on. For 'source property', a URI is expected specifying the property the restriction is on. For 'source on class', a URI is expected specifying the filler class of a qualified cardinality restriction; if omitted, the restriction is assumed to be unqualified."@en ;
                              :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteCardinalityRestriction.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteCardinalityRestriction ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the class the restriction is on. For 'source property', a URI is expected specifying the property the restriction is on. For 'source on class', a URI is expected specifying the filler class of a qualified cardinality restriction; if omitted, the restriction is assumed to be unqualified."@en ;
   :hasOptionalParameter :sourceOnClass ;
   :hasRequiredParameter :sourceNode ,
                         :sourceProperty
 ] .


###  https://w3id.org/refract#DeleteClass
:DeleteClass rdf:type owl:Class ;
             rdfs:subClassOf :SemanticAction ,
                             :StructuralAction ;
             rdfs:comment "A structural and semantic action that deletes a class from either the source ontology or the target ontology."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "Delete class"@en ;
             :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteClass.ttl> ;
             :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. In most cases, the class being deleted belongs to the source ontology. A class may also be deleted from the target ontology, for example when a temporary class was created as an intermediate step in the transformation process. For 'check for assertion', a value from 'Algorithm check - assertion' is expected. If existing assertions for the class are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
             :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteClass.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteClass ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided. In most cases, the class being deleted belongs to the source ontology. A class may also be deleted from the target ontology, for example when a temporary class was created as an intermediate step in the transformation process. For 'check for assertion', a value from 'Algorithm check - assertion' is expected. If existing assertions for the class are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasOptionalParameterWithFallback :checkForAssertion
 ] .


###  https://w3id.org/refract#DeleteDataProperty
:DeleteDataProperty rdf:type owl:Class ;
                    rdfs:subClassOf :StructuralAction ;
                    rdfs:comment "A structural action that deletes a data property from the source ontology."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "Delete data property"@en ;
                    :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteDataProperty.ttl> ;
                    :hasParameters "For 'source node', a URI is expected. If existing assertions for the data property are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
                    :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteDataProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteDataProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected. If existing assertions for the data property are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
   :hasOptionalParameterWithFallback :checkForAssertion ;
   :hasRequiredParameter :sourceNode
 ] .


###  https://w3id.org/refract#DeleteInstance
:DeleteInstance rdf:type owl:Class ;
                rdfs:subClassOf :SemanticAction ;
                rdfs:comment "A semantic action that deletes a named individual from the source ontology."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "Delete instance"@en ;
                :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteInstance.ttl> ;
                :hasParameters "For 'source node', a URI is expected specifying the individual to be deleted. If existing assertions for the individual are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
                :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteInstance.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteInstance ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the individual to be deleted. If existing assertions for the individual are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
   :hasOptionalParameterWithFallback :checkForAssertion ;
   :hasRequiredParameter :sourceNode
 ] .


###  https://w3id.org/refract#DeleteInstancePropertyAssertion
:DeleteInstancePropertyAssertion rdf:type owl:Class ;
                                 rdfs:subClassOf :SemanticAction ;
                                 rdfs:comment "A semantic action that deletes an object or data property assertion from a named individual in the ontology. For class-level property usage, use 'Delete property restriction' or 'Delete semantic axiom' instead."@en ;
                                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                                 rdfs:label "Delete instance property assertion"@en ;
                                 :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteInstancePropertyAssertion.ttl> ;
                                 :hasParameters "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided, specifying the named individual. For 'target object', a URI is expected specifying the property. For 'target object value', a URI is expected specifying the value of the assertion to be deleted."@en ;
                                 :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteInstancePropertyAssertion.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteInstancePropertyAssertion ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "Either 'source node' or 'target node' must be specified, but not both. A URI is expected for whichever is provided, specifying the named individual. For 'target object', a URI is expected specifying the property. For 'target object value', a URI is expected specifying the value of the assertion to be deleted."@en ;
   :hasOptionalParameterWithAtLeastOne :sourceNode ,
                                       :targetNode ;
   :hasRequiredParameter :targetObject ,
                         :targetObjectValue
 ] .


###  https://w3id.org/refract#DeleteObjectProperty
:DeleteObjectProperty rdf:type owl:Class ;
                      rdfs:subClassOf :StructuralAction ;
                      rdfs:comment "A structural action that deletes an object property from the source ontology."@en ;
                      rdfs:isDefinedBy <https://w3id.org/refract> ;
                      rdfs:label "Delete object property"@en ;
                      :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteObjectProperty.ttl> ;
                      :hasParameters "For 'source node', a URI is expected. If existing assertions for the object property are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
                      :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteObjectProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteObjectProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected. If existing assertions for the object property are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
   :hasOptionalParameterWithFallback :checkForAssertion ;
   :hasRequiredParameter :sourceNode
 ] .


###  https://w3id.org/refract#DeletePropertyDomainRange
:DeletePropertyDomainRange rdf:type owl:Class ;
                           rdfs:subClassOf :SemanticAction ;
                           rdfs:comment "A semantic action that deletes a domain or range assertion from an object or data property in the ontology."@en ;
                           rdfs:isDefinedBy <https://w3id.org/refract> ;
                           rdfs:label "Delete property domain or range assertion"@en ;
                           :exampleTMF <https://semanticweb.tools/rdf/tmf/DeletePropertyDomainRange.ttl> ;
                           :hasParameters "For 'source node', a URI is expected specifying the property. For 'axiom type', either rdfs:domain or rdfs:range is expected."@en ;
                           :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeletePropertyDomainRange.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeletePropertyDomainRange ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the property. For 'axiom type', either rdfs:domain or rdfs:range is expected."@en ;
   :hasRequiredParameter :axiomType ,
                         :sourceNode
 ] .


###  https://w3id.org/refract#DeletePropertyRestriction
:DeletePropertyRestriction rdf:type owl:Class ;
                           rdfs:subClassOf :SemanticAction ;
                           rdfs:comment "A semantic action that deletes an existential or universal property restriction from a class in the ontology."@en ;
                           rdfs:isDefinedBy <https://w3id.org/refract> ;
                           rdfs:label "Delete property restriction"@en ;
                           :exampleTMF <https://semanticweb.tools/rdf/tmf/DeletePropertyRestriction.ttl> ;
                           :hasParameters "For 'source node', a URI is expected specifying the class the restriction is on. For 'target object', a URI is expected specifying the property of the restriction. For 'target object value', a URI is expected specifying the filler class of the restriction. For 'restriction type', either owl:someValuesFrom (existential) or owl:allValuesFrom (universal) is expected."@en ;
                           :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeletePropertyRestriction.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeletePropertyRestriction ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the class the restriction is on. For 'target object', a URI is expected specifying the property of the restriction. For 'target object value', a URI is expected specifying the filler class of the restriction. For 'restriction type', either owl:someValuesFrom (existential) or owl:allValuesFrom (universal) is expected."@en ;
   rdfs:comment :restrictionType ;
   :hasRequiredParameter :sourceNode ,
                         :targetObject ,
                         :targetObjectValue
 ] .


###  https://w3id.org/refract#DeleteSemanticAxiom
:DeleteSemanticAxiom rdf:type owl:Class ;
                     rdfs:subClassOf :SemanticAction ;
                     rdfs:comment "A catch-all semantic action that deletes a binary semantic axiom between two ontology elements. Use a dedicated action where one exists for the specific axiom type."@en ;
                     rdfs:isDefinedBy <https://w3id.org/refract> ;
                     rdfs:label "Delete semantic axiom"@en ;
                     :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteSemanticAxiom.ttl> ;
                     :hasParameters "For 'source node', a URI is expected specifying the subject of the axiom. For 'target node', a URI is expected specifying the object of the axiom. For 'axiom type', a URI is expected specifying the OWL or RDF axiom type to be deleted."@en ;
                     :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteSemanticAxiom.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteSemanticAxiom ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the subject of the axiom. For 'target node', a URI is expected specifying the object of the axiom. For 'axiom type', a URI is expected specifying the OWL or RDF axiom type to be deleted."@en ;
   :hasRequiredParameter :axiomType ,
                         :sourceNode ,
                         :targetNode
 ] .


###  https://w3id.org/refract#DeleteSuperclassAssertion
:DeleteSuperclassAssertion rdf:type owl:Class ;
                           rdfs:subClassOf :SemanticAction ;
                           rdfs:comment "A semantic action that deletes a superclass assertion from a class in the ontology. This action does not delete the class itself; to delete a class, use 'Delete class'."@en ;
                           rdfs:isDefinedBy <https://w3id.org/refract> ;
                           rdfs:label "Delete superclass assertion"@en ;
                           :exampleTMF <https://semanticweb.tools/rdf/tmf/DeleteSuperclassAssertion.ttl> ;
                           :hasParameters "For 'source node', a URI is expected specifying the class. One or more source nodes may be specified. For 'target parent', a URI is expected specifying the superclass assertion to be deleted."@en ;
                           :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeleteSuperclassAssertion.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeleteSuperclassAssertion ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the class. One or more source nodes may be specified. For 'target parent', a URI is expected specifying the superclass assertion to be deleted."@en ;
   :hasRequiredParameter :sourceNode ,
                         :targetParent
 ] .


###  https://w3id.org/refract#DeprecateClass
:DeprecateClass rdf:type owl:Class ;
                rdfs:subClassOf :SemanticAction ,
                                :StructuralAction ;
                rdfs:comment "A structural and semantic action that deprecates a class in the source ontology."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "Deprecate class"@en ;
                rdfs:seeAlso :DeprecateClassWithSuccessor ;
                :exampleTMF <https://semanticweb.tools/rdf/tmf/DeprecateClass.ttl> ;
                :hasParameters "For 'source node', a URI is expected. Multiple source nodes may be specified, allowing more than one class to be deprecated by the same refactoring action. The algorithm adds an owl:deprecated annotation with value \"true\"^^xsd:boolean to each specified class."@en ;
                :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeprecateClass.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeprecateClass ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected. Multiple source nodes may be specified, allowing more than one class to be deprecated by the same refactoring action. The algorithm adds an owl:deprecated annotation with value \"true\"^^xsd:boolean to each specified class."@en ;
   :hasOptionalParameter :actionSequence ;
   :hasRequiredParameter :sourceNode
 ] .


###  https://w3id.org/refract#DeprecateClassWithSuccessor
:DeprecateClassWithSuccessor rdf:type owl:Class ;
                             rdfs:subClassOf :CompositeAction ;
                             rdfs:comment "A composite refactoring action that deprecates a class and adds a successor class."@en ;
                             rdfs:isDefinedBy <https://w3id.org/refract> ;
                             rdfs:label "Deprecate class with successor class"@en ;
                             :exampleTMF <https://semanticweb.tools/rdf/tmf/DeprecateClassWithSuccessor.ttl> ;
                             :hasActions "At least one 'Deprecate class' action and one 'Add class' action are required. Optionally, one or more annotation actions may be included, such as 'Add annotation - langString', 'Add annotation', or 'Add comment for deprecation'."@en ;
                             :hasParameters "The constituent atomic actions are linked via 'has action' and executed in the order specified by 'action sequence' in each atomic action.  If two or more actions have the same sequence number, the transformation algorithm resolves the order by their order of appearance in the Transformation Manifest File. At least two actions are required."@en ;
                             :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeDeprecateClassWithSuccessor.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeprecateClassWithSuccessor ;
   owl:annotatedProperty :hasActions ;
   owl:annotatedTarget "At least one 'Deprecate class' action and one 'Add class' action are required. Optionally, one or more annotation actions may be included, such as 'Add annotation - langString', 'Add annotation', or 'Add comment for deprecation'."@en ;
   :isOptionalAction :AddAnnotation ,
                     :AddAnnotationLangString ,
                     :AddCommentForDeprecation ;
   :isRequiredAction :AddClass ,
                     :DeprecateClass
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeprecateClassWithSuccessor ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "The constituent atomic actions are linked via 'has action' and executed in the order specified by 'action sequence' in each atomic action.  If two or more actions have the same sequence number, the transformation algorithm resolves the order by their order of appearance in the Transformation Manifest File. At least two actions are required."@en ;
   :hasRequiredParameter :hasAction
 ] .


###  https://w3id.org/refract#DifferentRelationship
:DifferentRelationship rdf:type owl:Class ;
                       rdfs:subClassOf :URIRelationship ;
                       rdfs:comment "Indicates that the target ontology is published to an entirely new URI, unrelated to that of the source ontology. A fallback URI should be declared in this case."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Different relationship"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DifferentRelationship ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Indicates that the target ontology is published to an entirely new URI, unrelated to that of the source ontology. A fallback URI should be declared in this case."@en ;
   rdfs:seeAlso :fallbackOntologyURI
 ] .


###  https://w3id.org/refract#DirectEquivalent
:DirectEquivalent rdf:type owl:Class ;
                  rdfs:subClassOf :SemanticCategory ;
                  rdfs:comment "A semantic category indicating that the source and target concepts have equal individuals, and the axiom pattern and superclass are both equivalent between the source and target viewpoints."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Direct equivalent"@en .


###  https://w3id.org/refract#GlobalAction
:GlobalAction rdf:type owl:Class ;
              rdfs:subClassOf :RefactoringAction ;
              rdfs:comment "A macro-level refactoring action that operates on an ontology as a whole, rather than on individual ontology elements."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "Global action"@en .


###  https://w3id.org/refract#GranularityMismatch
:GranularityMismatch rdf:type owl:Class ;
                     rdfs:subClassOf :SemanticCategory ;
                     rdfs:comment "A semantic category indicating that the source and target concepts have a granularity difference, where the individuals of one concept are a proper subset of the other. The axiom pattern and superclass may be equivalent or may differ between the source and target viewpoints."@en ;
                     rdfs:isDefinedBy <https://w3id.org/refract> ;
                     rdfs:label "Granularity mismatch"@en .


###  https://w3id.org/refract#ImportOntology
:ImportOntology rdf:type owl:Class ;
                rdfs:subClassOf :GlobalAction ;
                rdfs:comment "A global refactoring action that adds an owl:imports statement to an ontology, declaring a dependency on an external ontology."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "Import ontology"@en ;
                :exampleTMF <https://semanticweb.tools/rdf/tmf/ImportOntology.ttl> ;
                :hasParameters "For 'source node', a URI is expected specifying the ontology to which the import statement is being added. For 'URI', an xsd:anyURI value is expected specifying the ontology to be imported. Note that this action does not add a namespace prefix declaration. To add a namespace prefix, use 'Add namespace prefix'."@en ;
                :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeImportOntology.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ImportOntology ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node', a URI is expected specifying the ontology to which the import statement is being added. For 'URI', an xsd:anyURI value is expected specifying the ontology to be imported. Note that this action does not add a namespace prefix declaration. To add a namespace prefix, use 'Add namespace prefix'."@en ;
   :hasRequiredParameter :URI ,
                         :sourceNode
 ] .


###  https://w3id.org/refract#IndirectEquivalent
:IndirectEquivalent rdf:type owl:Class ;
                    rdfs:subClassOf :SemanticCategory ;
                    rdfs:comment "A semantic category indicating that the source and target concepts have equal individuals, but the axiom pattern or superclass (or both) differ between the source and target viewpoints."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "Indirect equivalent"@en .


###  https://w3id.org/refract#LocalAction
:LocalAction rdf:type owl:Class ;
             rdfs:subClassOf :RefactoringAction ;
             rdfs:comment "A micro-level refactoring action that operates on individual ontology elements. Local actions are further classified as either atomic or composite."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "Local action"@en .


###  https://w3id.org/refract#Manifest
:Manifest rdf:type owl:Class ;
          rdfs:subClassOf rdfs:Resource ;
          rdfs:comment "A Transformation Manifest File (TMF) that records the metadata and refactoring actions associated with an ontology transformation process. A manifest declares the source ontology, the transformation process type, the URI relationship to the source, version metadata, and the set of refactoring actions to be applied."@en ;
          rdfs:isDefinedBy <https://w3id.org/refract> ;
          rdfs:label "Manifest"@en .


###  https://w3id.org/refract#NoCorrespondence
:NoCorrespondence rdf:type owl:Class ;
                  rdfs:subClassOf :SemanticCategory ;
                  rdfs:comment "A semantic category indicating that there are no shared individuals between the source and target concepts, such that there is no conceptual correspondence between the source and target viewpoints."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "No correspondence"@en .


###  https://w3id.org/refract#OntologyEvolutionProcess
:OntologyEvolutionProcess rdf:type owl:Class ;
                          rdfs:subClassOf :TransformationProcess ;
                          rdfs:comment "A transformation process that modifies an ontology to reflect changes in the domain it models. Characterised by: same viewpoint, same URI (versioned), and semantic changes driven by a real-world domain change. Examples include adding or removing classes and properties in response to changes in the world."@en ;
                          rdfs:isDefinedBy <https://w3id.org/refract> ;
                          rdfs:label "Ontology evolution process"@en ;
                          :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeEvolution.ttl> .


###  https://w3id.org/refract#OntologyLocalisationProcess
:OntologyLocalisationProcess rdf:type owl:Class ;
                             rdfs:subClassOf :OntologyTransformationProcess ;
                             rdfs:comment "A transformation process that adapts an ontology to a specific cultural, linguistic, or regional viewpoint. A subclass of 'Ontology transformation process'. Characterised by: different viewpoint, different URI, and semantic changes driven by a community-specific viewpoint."@en ;
                             rdfs:isDefinedBy <https://w3id.org/refract> ;
                             rdfs:label "Ontology localisation process"@en ;
                             :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeLocalisation.ttl> .


###  https://w3id.org/refract#OntologyRefactoringProcess
:OntologyRefactoringProcess rdf:type owl:Class ;
                            rdfs:subClassOf :TransformationProcess ;
                            rdfs:comment "A transformation process that modifies an ontology without changing its intended meaning. Characterised by: same viewpoint, same URI (versioned), and structural changes only with no semantic or domain change. Examples include renaming classes or properties."@en ;
                            rdfs:isDefinedBy <https://w3id.org/refract> ;
                            rdfs:label "Ontology refactoring process"@en ;
                            :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeRefactoring.ttl> .


###  https://w3id.org/refract#OntologyTransformationProcess
:OntologyTransformationProcess rdf:type owl:Class ;
                               rdfs:subClassOf :TransformationProcess ;
                               rdfs:comment "A transformation process that produces a new ontology from an existing one, representing a different viewpoint or context. Characterised by: different viewpoint, different URI, and semantic changes driven by a different viewpoint or conte"@en ;
                               rdfs:isDefinedBy <https://w3id.org/refract> ;
                               rdfs:label "Ontology transformation process"@en ;
                               :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeTransformation.ttl> .


###  https://w3id.org/refract#OntologyView
:OntologyView rdf:type owl:Class ;
              rdfs:subClassOf <http://www.w3.org/ns/shacl#Target> ;
              rdfs:comment "A class representing an ontology view — the transformation of a source ontology to a target viewpoint, where both the semantic and annotation layers are adapted as required. In the context of internationalisation, a view is specific to a culture, language, or region. Modelled as a subclass of sh:Target to enable view-specific SHACL validation."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "Ontology view"@en .


###  https://w3id.org/refract#OverlappingMeaning
:OverlappingMeaning rdf:type owl:Class ;
                    rdfs:subClassOf :SemanticCategory ;
                    rdfs:comment "A semantic category indicating that the source and target concepts share only some individuals (an intersection), where neither is a subset of the other, and the axiom pattern or superclass may be equivalent or may differ between the source and target viewpoints."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "Overlapping meaning"@en .


###  https://w3id.org/refract#RefactoringAction
:RefactoringAction rdf:type owl:Class ;
                   rdfs:subClassOf prov:Activity ;
                   rdfs:comment "An activity that applies a refactoring action to an ontology. Refactoring actions are classified as either global actions, which operate at the ontology level, or local actions, which operate at the level of individual ontology elements. For example, localising the English concept :River into French requires deleting the original class and replacing it with two sibling classes, :Riviere (a river that flows into another river) and :Fleuve (a river that flows into the sea)."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "Refactoring action"@en .


###  https://w3id.org/refract#RenameClass
:RenameClass rdf:type owl:Class ;
             rdfs:subClassOf :StructuralAction ;
             rdfs:comment "A structural action that renames a class in the ontology by replacing its URI (or fragment identifier) with a new URI."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "Rename class"@en ;
             :exampleTMF <https://semanticweb.tools/rdf/tmf/RenameClass.ttl> ;
             :hasParameters "For 'source node' and 'target identifier', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If existing assertions for the class are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
             :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeRenameClass.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :RenameClass ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node' and 'target identifier', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If existing assertions for the class are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
   :hasOptionalParameterWithFallback :checkForAssertion ;
   :hasRequiredParameter :sourceNode ,
                         :targetIdentifier ,
                         :targetLabel ,
                         :targetLanguageTag
 ] .


###  https://w3id.org/refract#RenameProperty
:RenameProperty rdf:type owl:Class ;
                rdfs:subClassOf :StructuralAction ;
                rdfs:comment "A structural action that renames a property (object, data, or annotation) in the ontology by replacing its URI (or fragment identifier) with a new URI."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "Rename property"@en ;
                :exampleTMF <https://semanticweb.tools/rdf/tmf/RenameProperty.ttl> ;
                :hasParameters "For 'source node' and 'target identifier', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If existing assertions for the property are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
                :hasShapesGraph <https://semanticweb.tools/rdf/shapes/ShapeRenameProperty.ttl> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :RenameProperty ;
   owl:annotatedProperty :hasParameters ;
   owl:annotatedTarget "For 'source node' and 'target identifier', a URI is expected. For 'target label' and 'target language tag', a plain string is expected (no language tag). If existing assertions for the property are found during pre-processing (and there is no corresponding deletion refactoring action for those assertions), the behaviour of the transformation algorithm is determined by the value of 'check for assertion'. If 'check for assertion' is omitted, the algorithm defaults to 'If true - stop'."@en ;
   :hasOptionalParameterWithFallback :checkForAssertion ;
   :hasRequiredParameter :sourceNode ,
                         :targetIdentifier ,
                         :targetLabel ,
                         :targetLanguageTag
 ] .


###  https://w3id.org/refract#SameUnversionedRelationship
:SameUnversionedRelationship rdf:type owl:Class ;
                             rdfs:subClassOf :URIRelationship ;
                             rdfs:comment "Indicates that the target ontology is published to the same URI as the source ontology, without versioning."@en ;
                             rdfs:isDefinedBy <https://w3id.org/refract> ;
                             rdfs:label "Same unversioned relationship"@en .


###  https://w3id.org/refract#SameVersionedRelationship
:SameVersionedRelationship rdf:type owl:Class ;
                           rdfs:subClassOf :URIRelationship ;
                           rdfs:comment "Indicates that the target ontology is published to the same URI as the source ontology, with versioning."@en ;
                           rdfs:isDefinedBy <https://w3id.org/refract> ;
                           rdfs:label "Same versioned relationship"@en .


###  https://w3id.org/refract#SemanticAction
:SemanticAction rdf:type owl:Class ;
                rdfs:subClassOf :AtomicAction ;
                rdfs:comment "An atomic action that results in a change to the semantic meaning of the ontology. For example, adding a superclass assertion changes the ontological commitment of a class without introducing a new ontology element. A refactoring action may be both a semantic and a structural action — for example, adding a class introduces a new ontology element and simultaneously carries ontological commitment."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "Semantic action"@en .


###  https://w3id.org/refract#SemanticCategory
:SemanticCategory rdf:type owl:Class ;
                  rdfs:subClassOf rdfs:Resource ;
                  rdfs:comment "A semantic category that characterises the conceptual relationship between a source concept and its corresponding concept(s) in the target viewpoint, based on the set-theoretic equivalence of their extensions as ontology individuals."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Semantic category"@en .


###  https://w3id.org/refract#StructuralAction
:StructuralAction rdf:type owl:Class ;
                  rdfs:subClassOf :AtomicAction ;
                  rdfs:comment "An atomic action that adds or removes an ontology element, such as a class, object property, or annotation property, without necessarily affecting the semantic meaning of the ontology. For example, adding an object property is a structural change; the semantic meaning of the ontology is only affected once an assertion is made using that property. A refactoring action may be both a structural and a semantic action - for example, adding a class introduces a new ontology element and simultaneously carries ontological commitment."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "Structural action"@en .


###  https://w3id.org/refract#TargetSameAsSource
:TargetSameAsSource rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/shacl#Target> ;
                    rdfs:comment "A SHACL target that applies validation to ontologies where the target is the same as the source, used in refactoring and evolution processes where the URI relationship is 'same versioned' or 'same unversioned'."@en ;
                    rdfs:isDefinedBy <https://w3id.org/refract> ;
                    rdfs:label "Target same as source"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :TargetSameAsSource ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "A SHACL target that applies validation to ontologies where the target is the same as the source, used in refactoring and evolution processes where the URI relationship is 'same versioned' or 'same unversioned'."@en ;
   rdfs:seeAlso :SameUnversionedRelationship ,
                :SameVersionedRelationship
 ] .


###  https://w3id.org/refract#TransformationProcess
:TransformationProcess rdf:type owl:Class ;
                       rdfs:subClassOf rdfs:Class ;
                       rdfs:comment "A process that transforms one or more ontologies or knowledge graphs into a new form."@en ;
                       rdfs:isDefinedBy <https://w3id.org/refract> ;
                       rdfs:label "Transformation process"@en .


###  https://w3id.org/refract#URIRelationship
:URIRelationship rdf:type owl:Class ;
                 rdfs:subClassOf rdfs:Resource ;
                 rdfs:comment "A class representing the relationship between the URI of a source ontology and the URI of its target ontology in a transformation process."@en ;
                 rdfs:isDefinedBy <https://w3id.org/refract> ;
                 rdfs:label "URI relationship"@en .


###  https://w3id.org/refract#Version
:Version rdf:type owl:Class ;
         rdfs:subClassOf rdfs:Resource ;
         rdfs:comment "A class representing the version metadata of a Transformation Manifest File. Version metadata includes the version number, the date of the version, the previous version, and the contributors to the TMF."@en ;
         rdfs:isDefinedBy <https://w3id.org/refract> ;
         rdfs:label "Version"@en .


#################################################################
#    Individuals
#################################################################

###  https://w3id.org/refract#IfFalseAdd
:IfFalseAdd rdf:type owl:NamedIndividual ,
                     :AlgorithmCheckAnnotation ;
            rdfs:comment "Indicates that the transformation algorithm should add the annotation if it is not found during pre-processing, and proceed with execution."@en ;
            rdfs:isDefinedBy <https://w3id.org/refract> ;
            rdfs:label "If false - add"@en .


###  https://w3id.org/refract#IfFalseIgnore
:IfFalseIgnore rdf:type owl:NamedIndividual ,
                        :AlgorithmCheckAnnotation ;
               rdfs:comment "Indicates that the transformation algorithm should suppress the violation and skip the change annotation action if the annotation is not found during pre-processing."@en ;
               rdfs:isDefinedBy <https://w3id.org/refract> ;
               rdfs:label "If false - ignore"@en .


###  https://w3id.org/refract#IfFalseStop
:IfFalseStop rdf:type owl:NamedIndividual ,
                      :AlgorithmCheckAnnotation ;
             rdfs:comment "Indicates that the transformation algorithm should halt and report a violation if the annotation to be changed is not found during pre-processing. The algorithm will need to be restarted."@en ;
             rdfs:isDefinedBy <https://w3id.org/refract> ;
             rdfs:label "If false - stop"@en .


###  https://w3id.org/refract#IfMultipleIgnore
:IfMultipleIgnore rdf:type owl:NamedIndividual ,
                           :AlgorithmCheckAnnotation ;
                  rdfs:comment "Indicates that the transformation algorithm should suppress the violation and skip the change annotation action if more than one annotation is found for the same annotation property (and language tag combination) during pre-processing."@en ;
                  rdfs:isDefinedBy <https://w3id.org/refract> ;
                  rdfs:label "If multiple - ignore"@en .


###  https://w3id.org/refract#IfMultipleStop
:IfMultipleStop rdf:type owl:NamedIndividual ,
                         :AlgorithmCheckAnnotation ;
                rdfs:comment "Indicates that the transformation algorithm should halt and report a violation if more than one annotation is found for the same annotation property (and language tag combination) during pre-processing. The algorithm will need to be restarted."@en ;
                rdfs:isDefinedBy <https://w3id.org/refract> ;
                rdfs:label "If multiple - stop"@en .


###  https://w3id.org/refract#IfTrueDelete
:IfTrueDelete rdf:type owl:NamedIndividual ,
                       :AlgorithmCheckAssertion ;
              rdfs:comment "Indicates that the transformation algorithm should delete the existing assertions if found during pre-processing, and proceed with execution."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "If true - delete"@en .


###  https://w3id.org/refract#IfTrueIgnore
:IfTrueIgnore rdf:type owl:NamedIndividual ,
                       :AlgorithmCheckAssertion ;
              rdfs:comment "Indicates that the transformation algorithm should suppress the violation and proceed with execution if existing assertions are found during pre-processing."@en ;
              rdfs:isDefinedBy <https://w3id.org/refract> ;
              rdfs:label "If true - ignore"@en .


###  https://w3id.org/refract#IfTrueStop
:IfTrueStop rdf:type owl:NamedIndividual ,
                     :AlgorithmCheckAssertion ;
            rdfs:comment "Indicates that the transformation algorithm should halt and report a violation if existing assertions are found during pre-processing. The algorithm will need to be restarted."@en ;
            rdfs:isDefinedBy <https://w3id.org/refract> ;
            rdfs:label "If true - stop"@en .


###  https://w3id.org/refract#NoPreviousVersion
:NoPreviousVersion rdf:type owl:NamedIndividual ,
                            :Version ;
                   rdfs:comment "A named individual indicating that a Transformation Manifest File has no previous version, i.e. it is the first version of the manifest."@en ;
                   rdfs:isDefinedBy <https://w3id.org/refract> ;
                   rdfs:label "No previous version"@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :NoPreviousVersion ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "A named individual indicating that a Transformation Manifest File has no previous version, i.e. it is the first version of the manifest."@en ;
   rdfs:seeAlso :Manifest
 ] .


