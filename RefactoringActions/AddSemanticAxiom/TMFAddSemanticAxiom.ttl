@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sweetfr: <https://example.org/sweet/fr#> .

fract:tmf_AddSemanticAxiom a fract:Manifest ;
    fract:transformationType fract:OntologyLocalisationProcess ;
    fract:transformationSource <http://sweetontology.net/realmHydroBody> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_AddSemanticAxiom_1 .

fract:action_AddSemanticAxiom_1 a fract:AddSemanticAxiom ;
    fract:sourceNode sweetfr:Riviere ;
    fract:axiomType owl:disjointWith ;
    fract:targetNode sweetfr:Fleuve ;
    dash:shape shape:ShapeAddSemanticAxiom .
