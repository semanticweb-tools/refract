@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ex: <http://example.org/> .

fract:tmf_DeleteInstancePropertyAssertion a fract:Manifest ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_DeleteInstancePropertyAssertion_1 .

fract:action_DeleteInstancePropertyAssertion_1 a fract:DeleteInstancePropertyAssertion ;
    fract:sourceNode ex:PfizerBioNTech ;
    fract:targetObject ex:hasManufacturer ;
    fract:targetObjectValue ex:PfizerInc ;
    dash:shape shape:ShapeDeleteInstancePropertyAssertion .
