@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeDeleteInstancePropertyAssertion
    a sh:NodeShape ;
    rdfs:label "Shape Delete Instance Property Assertion" ;
    rdfs:comment "A shapes graph for validating a 'Delete instance property assertion' refactoring action in a Transformation Manifest File." ;
    sh:targetClass ref:DeleteInstancePropertyAssertion ;
    sh:xone (
        [ sh:property [ sh:path ref:sourceNode ; sh:name "source node" ; sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
        [ sh:property [ sh:path ref:targetNode ; sh:name "target node" ; sh:description "The URI of an ontology element that already exists in the target ontology, or has been created during the transformation process, and is then referenced by a refactoring action during the same transformation process." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
    ) ;
    sh:property [
        sh:path ref:targetObject ;
        sh:name "target object" ;
        sh:description "The URI of the object property used in a restriction or axiom as part of a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetObjectValue ;
        sh:name "target object value" ;
        sh:description "The URI of the filler class used in a restriction as part of a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] .
