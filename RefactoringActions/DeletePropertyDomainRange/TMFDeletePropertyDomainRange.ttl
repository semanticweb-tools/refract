@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mola: <https://semanticweb.tools/ont/mola#> .

fract:tmf_DeletePropertyDomainRange a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <https://semanticweb.tools/ont/mola> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_DeletePropertyDomainRange_1 .

fract:action_DeletePropertyDomainRange_1 a fract:DeletePropertyDomainRange ;
    fract:sourceNode mola:hasMember ;
    fract:axiomType rdfs:domain ;
    dash:shape shape:ShapeDeletePropertyDomainRange .
