@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeDeletePropertyDomainRange
    a sh:NodeShape ;
    rdfs:label "Shape Delete Property Domain or Range Assertion" ;
    rdfs:comment "A shapes graph for validating a 'Delete property domain or range assertion' refactoring action in a Transformation Manifest File." ;
    sh:targetClass ref:DeletePropertyDomainRange ;
    sh:property [
        sh:path ref:sourceNode ;
        sh:name "source node" ;
        sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:axiomType ;
        sh:name "axiom type" ;
        sh:description "Specifies the type of axiom used in a refactoring action. The value must be either rdfs:domain or rdfs:range." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in (rdfs:domain rdfs:range) ;
    ] .
