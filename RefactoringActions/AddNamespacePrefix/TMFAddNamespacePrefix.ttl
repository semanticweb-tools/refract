@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ref:tmf_AddNamespacePrefix a ref:Manifest ;
    ref:transformationType ref:OntologyRefactoringProcess ;
    ref:transformationSource <http://example.org/ontology> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:hasAction ref:action_AddNamespacePrefix_1 .

ref:action_AddNamespacePrefix_1 a ref:AddNamespacePrefix ;
    sh:prefix "skos" ;
    sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI ;
    dash:shape shape:ShapeAddNamespacePrefix .
