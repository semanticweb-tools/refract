@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ex: <http://example.org/ontology#> .

fract:tmf_ChangeSuperclassAssertion a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_ChangeSuperclassAssertion_1 .

fract:action_ChangeSuperclassAssertion_1 a fract:ChangeSuperclassAssertion ;
    fract:sourceNode ex:Fleuve ;
    fract:sourceParent ex:River ;
    fract:targetParent ex:NaturalWaterBody ;
    dash:shape shape:ShapeChangeSuperclassAssertion .
