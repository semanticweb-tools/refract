@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/ontology#> .

ref:tmf_ChangeAnnotation a ref:Manifest ;
    ref:transformationType ref:OntologyRefactoringProcess ;
    ref:transformationSource <http://example.org/ontology> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:hasAction ref:action_ChangeAnnotation_1 .

ref:action_ChangeAnnotation_1 a ref:ChangeAnnotation ;
    ref:sourceNode ex:River ;
    ref:targetAnnotation dct:issued ;
    ref:targetAnnotationValue "2016-01-01" ;
    ref:targetDataType xsd:date ;
    ref:checkForAnnotation ref:IfFalseStop ;
    ref:checkForAnnotation ref:IfMultipleStop ;
    dash:shape shape:ShapeChangeAnnotation .
