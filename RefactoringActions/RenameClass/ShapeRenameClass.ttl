@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeRenameClass
    a sh:NodeShape ;
    rdfs:label "Shape Rename Class" ;
    rdfs:comment "A shapes graph for validating a 'Rename class' refactoring action in a Transformation Manifest File." ;
    sh:targetClass ref:RenameClass ;
    sh:property [
        sh:path ref:sourceNode ;
        sh:name "source node" ;
        sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetIdentifier ;
        sh:name "target identifier" ;
        sh:description "The URI (or fragment identifier) of an ontology element to be created by a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetLabel ;
        sh:name "target label" ;
        sh:description "A plain string label for an ontology element that is to be created by a refactoring action." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetLanguageTag ;
        sh:name "target language tag" ;
        sh:description "A language tag expressed as a plain string, conforming to ISO 639 or BCP 47 (e.g. \"en-za\", \"fr\")." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:checkForAssertion ;
        sh:name "check for assertion" ;
        sh:description "Specifies the behaviour of the transformation algorithm when existing assertions are found during pre-processing for an element that is to be deleted. The value must be an instance of 'Algorithm check - assertion'. If this parameter is omitted, the algorithm defaults to 'If true - stop'." ;
        sh:class ref:AlgorithmCheckAssertion ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .
