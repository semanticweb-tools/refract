@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

shape:ShapeRenameClass
    a sh:NodeShape ;
    sh:targetClass ref:RenameClass ;
    sh:property [
        sh:path ref:sourceNode ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetIdentifier ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetLabel ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetLanguageTag ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:checkForAssertion ;
        sh:class ref:AlgorithmCheckAssertion ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .
