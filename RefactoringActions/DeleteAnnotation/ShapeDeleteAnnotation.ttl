@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeDeleteAnnotation
    a sh:NodeShape ;
    rdfs:label "Shape Delete Annotation" ;
    rdfs:comment "A shapes graph for validating a 'Delete annotation' refactoring action in a Transformation Manifest File." ;
    sh:targetClass fract:DeleteAnnotation ;
    sh:or (
        [ sh:property [ sh:path fract:sourceNode ; sh:name "source node" ; sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
        [ sh:property [ sh:path fract:targetNode ; sh:name "target node" ; sh:description "The URI of an ontology element that already exists in the target ontology, or has been created during the transformation process, and is then referenced by a refactoring action during the same transformation process." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
    ) ;
    sh:property [
        sh:path fract:targetAnnotation ;
        sh:name "target annotation" ;
        sh:description "The URI of an annotation property to be added to an ontology element as part of a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetLanguageTag ;
        sh:name "target language tag" ;
        sh:description "A language tag expressed as a plain string, conforming to ISO 639 or BCP 47 (e.g. \"en-za\", \"fr\"). For add actions, this specifies the language tag of the new annotation value or label. For change annotation actions, this is used to identify the specific annotation to be changed where more than one annotation exists for the same annotation property; it is not used to change the language tag itself. To change a language tag, use 'target language tag new'." ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .
