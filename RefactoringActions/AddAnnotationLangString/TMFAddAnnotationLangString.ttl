@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/ontology#> .

fract:tmf_AddAnnotationLangString a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_AddAnnotationLangString_1 .

fract:action_AddAnnotationLangString_1 a fract:AddAnnotationLangString ;
    fract:sourceNode ex:River ;
    fract:targetAnnotation rdfs:label ;
    fract:targetAnnotationValue "River" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .
