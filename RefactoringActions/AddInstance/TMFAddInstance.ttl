@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ex: <https://example.org/vo/> .

fract:tmf_AddInstance a fract:Manifest ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://purl.obolibrary.org/obo/vo.owl> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_AddInstance_1 .

fract:action_AddInstance_1 a fract:AddInstance ;
    fract:targetIdentifier ex:PfizerBioNTech ;
    fract:targetInstanceOf ex:mRNAVaccine ;
    fract:targetLabel "Pfizer-BioNTech COVID-19 vaccine" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddInstance .
