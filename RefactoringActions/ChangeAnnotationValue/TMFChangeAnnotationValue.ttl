@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/ontology#> .

fract:tmf_ChangeAnnotationValue a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_ChangeAnnotationValue_1 .

fract:action_ChangeAnnotationValue_1 a fract:ChangeAnnotationValue ;
    fract:sourceNode ex:River ;
    fract:targetAnnotation rdfs:comment ;
    fract:targetLanguageTag "en" ;
    fract:targetAnnotationValue "A natural waterbody that flows into the sea." ;
    fract:checkForAnnotation fract:IfFalseStop ;
    dash:shape shape:ShapeChangeAnnotationValue .
