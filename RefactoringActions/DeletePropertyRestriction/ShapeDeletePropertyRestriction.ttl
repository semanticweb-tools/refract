@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <http://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

shape:ShapeDeletePropertyRestriction
    a sh:NodeShape ;
    sh:targetClass ref:DeletePropertyRestriction ;
    sh:property [
        sh:path ref:sourceNode ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetObject ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetObjectValue ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:restrictionType ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in (owl:someValuesFrom owl:allValuesFrom) ;
    ] .