@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ref:tmf_ImportOntology a ref:Manifest ;
    ref:transformationType ref:OntologyRefactoringProcess ;
    ref:transformationSource <http://example.org/ontology> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:hasAction ref:action_ImportOntology_1 .

ref:action_ImportOntology_1 a ref:ImportOntology ;
    ref:sourceNode <http://example.org/ontology> ;
    ref:URI "http://www.w3.org/2004/02/skos/core"^^xsd:anyURI ;
    dash:shape shape:ShapeImportOntology .
