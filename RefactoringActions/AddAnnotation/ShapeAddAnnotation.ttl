@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeAddAnnotation
    a sh:NodeShape ;
    rdfs:label "Shape Add Annotation" ;
    rdfs:comment "A shapes graph for validating an 'Add annotation' refactoring action in a Transformation Manifest File." ;
    sh:targetClass fract:AddAnnotation ;
    sh:or (
        [ sh:property [ sh:path fract:sourceNode ; sh:name "source node" ; sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
        [ sh:property [ sh:path fract:targetNode ; sh:name "target node" ; sh:description "The URI of an ontology element that already exists in the target ontology, or has been created during the transformation process, and is then referenced by a refactoring action during the same transformation process." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
    ) ;
    sh:property [
        sh:path fract:targetAnnotation ;
        sh:name "target annotation" ;
        sh:description "The URI of an annotation property to be added to an ontology element as part of a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetAnnotationValue ;
        sh:name "target annotation value" ;
        sh:description "The value of an annotation to be added to an ontology element as part of a refactoring action, expressed as a plain string. The datatype of the value is specified by 'target datatype' for catch-all annotation actions, or is implicit in the dedicated annotation action type." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:not [ sh:datatype xsd:boolean ] ;
        sh:not [ sh:datatype xsd:date ] ;
        sh:not [ sh:datatype xsd:dateTime ] ;
        sh:not [ sh:datatype rdf:langString ] ;
    ] ;
    sh:property [
        sh:path fract:targetDataType ;
        sh:name "target datatype" ;
        sh:description "Specifies the datatype of a value in a refactoring action, for example an annotation value or a data property value. The value must be a URI representing a valid XSD, RDF, or OWL datatype." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
