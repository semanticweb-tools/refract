@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeLocalisation
    a sh:NodeShape ;
    rdfs:label "Shape Localisation" ;
    rdfs:comment "A macro-level shapes graph for validating the Transformation Manifest File of an ontology localisation process." ;
    sh:target [
        a dash:HasValueTarget ;
        dash:predicate fract:transformationType ;
        dash:object fract:OntologyLocalisationProcess ;
    ] ;
    sh:property [
        sh:path fract:transformationSource ;
        sh:name "transformation source" ;
        sh:description "The URI of the source ontology that is being transformed, refactored, evolved, or localised." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path fract:startingNode ;
        sh:name "starting node" ;
        sh:description "The URI of the root class from which a localisation process begins. If omitted, the localisation applies to the entire source ontology." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 0 ;
    ] ;
    sh:property [
        sh:path fract:hasURIRelationshipToSource ;
        sh:name "has URI relationship to source" ;
        sh:description "Specifies the URI relationship between the source and target ontology. The value must be a subclass of 'URI relationship'." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetOntologyURI ;
        sh:name "target ontology URI" ;
        sh:description "The URI of the target ontology produced by a transformation or localisation process." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetViewpoint ;
        sh:name "target viewpoint" ;
        sh:description "The URI of the viewpoint that the target ontology represents, as defined in the MULTI ontology." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path fract:versionManifest ;
        sh:name "version manifest" ;
        sh:description "Links a manifest to its version metadata, specified as an instance of 'Version'." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] .
